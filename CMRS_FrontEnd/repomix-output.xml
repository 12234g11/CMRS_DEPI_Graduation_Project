<file path="src/features/landing/landing.css">
section[id] {
  scroll-margin-top: 96px;
}

/* Navbar */
.landing-navbar {
  position: sticky;
  top: 0;
  z-index: 30;
  background: #ffffff;
  border-bottom: 1px solid rgba(2, 95, 72, 0.08);
  animation: navbar-slide-down 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  animation-fill-mode: both;
  will-change: transform, opacity;
}

@keyframes navbar-slide-down {
  from {
    opacity: 0;
    transform: translate3d(0, -24px, 0);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

.landing-navbar__inner {
  min-height: 76px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22px;
}

.landing-navbar__brand {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-shrink: 0;
}

.landing-navbar__brand-text {
  display: none;
}

.landing-navbar__brand strong,
.landing-navbar__brand span,
.landing-navbar__logo-mark {
  display: none;
}

.landing-navbar__logo-wrap {
  position: relative;
  width: 88px;
  height: 56px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.landing-navbar__logo-image {
    position: absolute;
    top: 68%;
    left: 50%;
    width: 230px;
    height: auto;
    max-width: none;
    display: block;
    object-fit: cover;
    transform: translate(-50%, -50%);
    transform-origin: center;
}


.landing-navbar__nav {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 22px;
  flex: 1;
}

.landing-navbar__nav-link {
  min-width: 58px;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  color: #333333;
  transform: translateY(0);
  transition:
    transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
    color 0.2s ease;
  will-change: transform;
}

.landing-navbar__nav-icon {
  width: 21px;
  height: 21px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: currentColor;
}

.landing-navbar__nav-label {
  font-size: 12px;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.landing-navbar__actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.landing-navbar__toggle {
  display: none;
  width: 46px;
  height: 46px;
  padding: 0;
  border: 1px solid rgba(2, 95, 72, 0.16);
  border-radius: 12px;
  background: #ffffff;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 5px;
  flex-shrink: 0;
}

.landing-navbar__toggle span {
  width: 20px;
  height: 2px;
  border-radius: 999px;
  background: var(--color-primary);
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.landing-navbar__toggle.is-active span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}

.landing-navbar__toggle.is-active span:nth-child(2) {
  opacity: 0;
}

.landing-navbar__toggle.is-active span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

.landing-navbar__mobile-menu {
  display: none;
}

/* Buttons */
.landing-btn {
  min-width: 132px;
  min-height: 48px;
  padding: 12px 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  font-weight: 700;
  transform: translateY(0);
  transition:
    transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
    background var(--transition-base),
    color var(--transition-base),
    border-color var(--transition-base),
    box-shadow 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform;
}

.landing-btn--primary {
  background: var(--color-primary);
  color: var(--color-white);
}

.landing-btn--primary:hover {
  background: var(--color-primary-dark);
}

.landing-btn--ghost {
  background: var(--color-white);
  border: 1px solid rgba(2, 95, 72, 0.22);
  color: var(--color-primary);
}

@media (hover: hover) and (pointer: fine) {
  .landing-btn:hover {
    transform: translateY(-2px);
  }

  .landing-navbar__nav-link:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  .landing-navbar__mobile-link:hover {
    transform: translateY(-2px);
    background: rgba(2, 95, 72, 0.08);
  }

  .landing-footer__socials a:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.18);
  }
}

/* Hero */
.hero-section {
  position: relative;
  min-height: calc(100vh - 76px);
  display: flex;
  align-items: center;
  background-color: #12342d;
  background:
    linear-gradient(90deg, rgba(3, 20, 16, 0.45), rgba(3, 20, 16, 0.2)),
    url('./images/hero-city.webp') center/cover no-repeat;
}

.hero-section__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.12);
}

.hero-section__content {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: flex-start;
  direction: rtl;
}

.hero-section__copy {
  width: 760px;
  max-width: 760px;
  padding-right: 72px;
  text-align: right;
  color: #f1f1f1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-section__title {
  margin: 0;
  font-family: var(--font-family-display, 'Cairo', sans-serif);
  font-weight: 800;
  font-size: 62px;
  line-height: 1.08;
  color: #f1f1f1;
  white-space: nowrap;
}

.hero-section__title span {
  color: #025f48;
  text-shadow: 0 0 3px rgba(0, 0, 0, 0.65), 0 0 6px rgba(0, 0, 0, 0.22);
}

.hero-section__subtitle {
  margin-top: 16px;
  margin-bottom: 0;
  width: 100%;
  max-width: 760px;
  font-family: var(--font-family-display, 'Cairo', sans-serif);
  font-weight: 700;
  font-size: 21px;
  line-height: 1.48;
  color: #f1f1f1;
}

.hero-section__subtitle-line {
  display: block;
}

.hero-section__subtitle-line--first {
  white-space: nowrap;
}

.hero-section__subtitle-line--second {
  margin-top: 2px;
}

.hero-section__actions {
  width: 100%;
  display: flex;
  justify-content: flex-start;
  margin-top: 24px;
}

.landing-btn--hero {
  min-width: 210px;
  height: 58px;
  padding: 0 24px;
  border-radius: 18px;
  background: #025f48;
  color: #f1f1f1;
  font-family: var(--font-family-display, 'Cairo', sans-serif);
  font-weight: 700;
  font-size: 20px;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px 10px rgba(2, 95, 72, 0.12);
}

/* Shared sections */
.landing-soft-section {
  background: linear-gradient(180deg, rgba(232, 255, 232, 0.8), rgba(245, 245, 245, 0));
}

.landing-section-heading {
  margin-bottom: 24px;
}

.landing-section-heading.is-centered {
  text-align: center;
}

.landing-section-heading h2 {
  color: var(--color-primary);
  font-size: clamp(1.75rem, 2.8vw, 2.6rem);
  line-height: 1.1;
  font-weight: 800;
}

.landing-section-heading p {
  margin-top: 8px;
  color: var(--color-subtitle);
  font-size: clamp(0.95rem, 1.25vw, 1.2rem);
  font-weight: 700;
  line-height: 1.4;
}

/* About */
#about.page-section {
  padding-bottom: 36px;
}

#about .about-section__cards {
  display: grid;
  gap: 18px;
}

#about .about-section__card {
  padding: 24px;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.7);
  color: var(--color-primary);
  font-size: clamp(0.95rem, 1.05vw, 1.1rem);
  font-weight: 700;
  text-align: center;
  box-shadow: var(--shadow-sm);
  line-height: 1.7;
}

/* Vision */
#vision.page-section {
  padding-top: 36px;
}

#vision .vision-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 22px 20px;
}

#vision .vision-card {
  text-align: center;
  padding: 6px 12px;
}

#vision .vision-card__badge {
  width: 38px;
  height: 38px;
  margin-inline: auto;
  margin-bottom: 12px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-white);
  font-size: 1.05rem;
  font-weight: 800;
}

#vision .vision-card h3 {
  color: var(--color-primary);
  font-size: clamp(1.05rem, 1.55vw, 1.55rem);
  font-weight: 800;
  line-height: 1.3;
}

#vision .vision-card p {
  margin-top: 10px;
  color: var(--color-subtitle);
  font-size: clamp(0.88rem, 0.98vw, 1.05rem);
  font-weight: 700;
  line-height: 1.65;
}

/* Services */
#services.page-section {
  position: relative;
  padding-top: 20px;
  padding-bottom: var(--section-space);
  background: transparent;
  overflow: hidden;
}

#services.page-section::before {
  content: '';
  position: absolute;
  inset: 0 0 auto 0;
  height: 122px;
  background: rgba(232, 255, 232, 0.78);
  z-index: 0;
}

#services .container {
  position: relative;
  z-index: 1;
}

#services .landing-section-heading {
  min-height: 92px;
  margin-bottom: 26px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.services-showcase {
  max-width: 1060px;
  margin: 0 auto;
}

.services-showcase__row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  direction: rtl;
  gap: 0;
}

.services-showcase__row--top .services-showcase__card {
  min-height: 348px;
}

.services-showcase__row--bottom .services-showcase__card {
  min-height: 282px;
}

.services-showcase__card {
  padding: 28px 26px 24px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.services-showcase__card h3 {
  margin: 0;
  font-size: clamp(1.25rem, 1.8vw, 2rem);
  font-weight: 800;
  line-height: 1.2;
}

.services-showcase__card h3::after {
  content: '';
  display: block;
  width: 122px;
  height: 3px;
  margin: 12px auto 0;
  border-radius: 999px;
  background: #9fd5c9;
}

.services-showcase__card ul {
  margin: 28px 0 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 28px;
}

.services-showcase__card li {
  font-size: clamp(0.98rem, 1.08vw, 1.28rem);
  font-weight: 700;
  line-height: 1.55;
}

.services-showcase__card--solid {
  background: #2f7d6b;
}

.services-showcase__card--solid h3,
.services-showcase__card--solid li {
  color: #ffffff;
}

.services-showcase__card--solid h3::after {
  background: rgba(232, 255, 232, 0.82);
}

.services-showcase__card--light h3 {
  color: var(--color-primary);
}

.services-showcase__card--light li {
  color: #9b9b9b;
}

/* How it works */
#how-it-works.page-section {
  padding-top: 32px;
  padding-bottom: 42px;
}

#how-it-works .landing-section-heading {
  margin-bottom: 24px;
}

#how-it-works .how-section {
  max-width: 1120px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
  align-items: stretch;
  direction: ltr;
}

#how-it-works .how-section__flow {
  direction: rtl;
  order: 1;
  display: grid;
  gap: 8px;
}

#how-it-works .how-section__image {
  order: 0;
  min-height: 620px;
  height: 100%;
  border-radius: 22px;
  background:
    linear-gradient(0deg, rgba(0, 0, 0, 0.12), rgba(0, 0, 0, 0.12)),
    url('./images/problem-example.webp') center/cover no-repeat;
  box-shadow: var(--shadow-md);
  position: relative;
}

#how-it-works .how-section__image-overlay {
  position: absolute;
  left: 16px;
  bottom: 16px;
  padding: 8px 14px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.9);
  color: var(--color-primary);
  font-weight: 800;
  font-size: 0.95rem;
}

#how-it-works .how-step-wrap {
  display: grid;
  justify-items: center;
}

#how-it-works .how-step {
  width: 100%;
  min-height: 72px;
  padding: 18px 22px;
  display: grid;
  place-items: center;
  text-align: center;
  border-radius: 16px;
  font-size: clamp(1rem, 1.08vw, 1.18rem);
  font-weight: 800;
  line-height: 1.4;
}

#how-it-works .how-step.is-solid {
  background: var(--color-primary);
  color: var(--color-white);
}

#how-it-works .how-step.is-light {
  background: var(--color-card);
  color: var(--color-primary);
  border: 1.5px solid var(--color-border);
}

#how-it-works .how-step__arrow {
  font-size: 1.5rem;
  color: var(--color-primary);
}

#how-it-works .how-step--wide {
  margin-top: 8px;
}

/* Contact */
#contact.page-section {
  padding-top: 34px;
  padding-bottom: 44px;
}

#contact .landing-section-heading {
  margin-bottom: 22px;
}

.contact-card {
  max-width: 980px;
  margin: 0 auto;
  padding: 26px 28px 30px;
  background: rgba(232, 255, 232, 0.72);
  border: 1.5px solid var(--color-border);
  border-radius: 24px;
}

.contact-form {
  display: grid;
  gap: 22px;
}

.contact-form__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22px 28px;
}

.contact-field {
  display: grid;
  gap: 10px;
}

.contact-field label {
  color: var(--color-primary);
  font-size: clamp(1.15rem, 1.5vw, 1.55rem);
  font-weight: 800;
  line-height: 1.3;
}

.contact-field input,
.contact-field textarea {
  padding: 14px 18px;
  font-size: clamp(0.98rem, 1vw, 1.08rem);
  font-weight: 700;
  border-radius: 14px;
  text-align: right;
  direction: rtl;
}

.contact-field textarea {
  min-height: 140px;
}

.contact-field input::placeholder,
.contact-field textarea::placeholder {
  color: #b5b5b5;
  text-align: right;
  direction: rtl;
}

#contact #phone {
  direction: ltr;
  text-align: right;
}

.landing-btn--submit {
  width: 100%;
  min-height: 58px;
  font-size: clamp(1.05rem, 1.2vw, 1.2rem);
  border-radius: 16px;
}

/* Footer */
.landing-footer {
  padding-top: 20px;
  background: linear-gradient(180deg, #0a7a5b, #066d52);
  color: var(--color-white);
}

.landing-footer__grid {
  padding-bottom: 14px;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr 1fr 0.8fr;
  gap: 22px;
  align-items: start;
}

.landing-footer__brand {
  display: grid;
  gap: 10px;
}

.landing-footer__logo-mark {
  display: none;
}

.landing-footer__logo-wrap {
  position: relative;
  width: 118px;
  height: 74px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.landing-footer__logo-image {
  position: absolute;
  top: 66%;
  left: 50%;
  width: 315px;
  height: auto;
  max-width: none;
  display: block;
  object-fit: cover;
  transform: translate(-50%, -50%);
  transform-origin: center;
}

.landing-footer__column {
  display: grid;
  gap: 10px;
}

.landing-footer h3 {
  margin: 0;
  color: #ffffff;
  font-size: clamp(1rem, 1.2vw, 1.35rem);
  font-weight: 800;
  line-height: 1.2;
  position: relative;
  width: fit-content;
  padding-bottom: 8px;
}

.landing-footer h3::after {
  content: '';
  position: absolute;
  right: 0;
  bottom: 0;
  width: 58px;
  height: 3px;
  border-radius: 999px;
  background: rgba(232, 255, 232, 0.8);
}

.landing-footer p,
.landing-footer li,
.landing-footer a {
  color: #ffffff;
  font-size: clamp(0.88rem, 0.92vw, 0.96rem);
  font-weight: 600;
  line-height: 1.6;
}

.landing-footer__links,
.landing-footer__contact-list {
  margin: 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 8px;
}

.landing-footer__contact-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.landing-footer__contact-icon {
  width: 28px;
  height: 28px;
  border-radius: 9px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}

.landing-footer__socials {
  display: flex;
  align-items: center;
  gap: 8px;
}

.landing-footer__socials a {
  width: 38px;
  height: 38px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.12);
  transform: translateY(0);
  transition:
    transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
    background var(--transition-base);
  will-change: transform;
}

.landing-footer__bottom {
  padding: 12px 10px;
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.14);
  font-size: 0.92rem;
  font-weight: 700;
}

/* Tablet */
@media (max-width: 992px) {
  .hero-section__copy {
    width: 620px;
    max-width: 620px;
    padding-right: 28px;
  }

  .hero-section__title {
    font-size: 54px;
    white-space: normal;
  }

  .hero-section__subtitle {
    max-width: 620px;
    font-size: 20px;
  }

  .hero-section__subtitle-line--first {
    white-space: normal;
  }

  .landing-btn--hero {
    min-width: 200px;
    height: 56px;
    font-size: 20px;
  }

  #services.page-section {
    padding-top: 16px;
  }

  #services.page-section::before {
    height: 106px;
  }

  #services .landing-section-heading {
    min-height: 82px;
  }

  .services-showcase__row {
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .services-showcase__row--top .services-showcase__card,
  .services-showcase__row--bottom .services-showcase__card {
    min-height: auto;
    border-radius: 20px;
  }

  .services-showcase__card {
    padding: 24px 20px;
  }

  .services-showcase__card ul {
    gap: 18px;
    margin-top: 22px;
  }

  #how-it-works.page-section {
    padding-top: 26px;
    padding-bottom: 34px;
  }

  #how-it-works .how-section {
    gap: 18px;
  }

  #how-it-works .how-section__image {
    min-height: 520px;
  }

  #how-it-works .how-step {
    min-height: 66px;
    padding: 16px 18px;
