<file path="src/features/user/reports/utils/buildReportPreviewImage.js">
const TONE_COLORS = {
  warning: {
    primary: '#f59e0b',
    secondary: '#fff7ed',
    surface: '#fffbeb',
  },
  info: {
    primary: '#3b82f6',
    secondary: '#eff6ff',
    surface: '#f8fbff',
  },
  success: {
    primary: '#10b981',
    secondary: '#ecfdf5',
    surface: '#f7fffb',
  },
  danger: {
    primary: '#ef4444',
    secondary: '#fef2f2',
    surface: '#fff8f8',
  },
  primary: {
    primary: '#025f48',
    secondary: '#e8fff4',
    surface: '#f7fffb',
  },
};

function escapeSvgText(value = '') {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

export function buildReportPreviewImage({
  title = 'بلاغ جديد',
  categoryLabel = 'أخرى',
  tone = 'warning',
} = {}) {
