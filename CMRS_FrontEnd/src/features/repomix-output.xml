/* Assignment confirmation modal */

.admin-assignment-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 2000;
  padding: 20px;
  background: rgba(0, 0, 0, 0.42);
  display: grid;
  place-items: center;
}

.admin-assignment-modal {
  position: relative;
  width: min(560px, 100%);
  padding: 24px;
  border-radius: 22px;
  background: #fff;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
}

.admin-assignment-modal__close {
  position: absolute;
  top: 16px;
  left: 16px;
  width: 36px;
  height: 36px;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.admin-assignment-modal__icon {
  width: 60px;
  height: 60px;
  margin: 0 auto 12px;
  border-radius: 50%;
  background: rgba(2, 95, 72, 0.1);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.admin-assignment-modal__icon svg {
  width: 28px;
  height: 28px;
}

.admin-assignment-modal h3 {
  color: var(--color-text);
  text-align: center;
  font-size: 1.2rem;
  font-weight: 950;
}

.admin-assignment-confirm-info {
  margin-top: 18px;
  display: grid;
  gap: 10px;
}

.admin-assignment-confirm-info p {
  padding: 12px;
  border-radius: 14px;
  background: #fafafa;
  display: grid;
  gap: 4px;
}

.admin-assignment-confirm-info span {
  color: var(--color-subtitle);
  font-size: 0.8rem;
  font-weight: 850;
}

.admin-assignment-confirm-info strong {
  color: var(--color-text);
  font-weight: 950;
}

.admin-assignment-note {
  margin-top: 14px;
  color: var(--color-text);
  display: grid;
  gap: 8px;
  font-weight: 900;
}

.admin-assignment-note textarea {
  width: 100%;
  resize: vertical;
  min-height: 110px;
  padding: 12px 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.16);
  border-radius: 14px;
  color: var(--color-text);
  font-weight: 850;
  outline: 0;
}

.admin-assignment-modal__actions {
  margin-top: 18px;
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

.admin-assignment-cancel-btn,
.admin-assignment-submit-btn {
  min-height: 42px;
  padding: 8px 18px;
  border-radius: 14px;
  font-weight: 950;
}

.admin-assignment-cancel-btn {
  background: #f2f2f2;
  color: var(--color-text);
}

.admin-assignment-submit-btn {
  background: var(--color-primary);
  color: #fff;
}

.admin-assignment-submit-btn:disabled {
  opacity: 0.75;
  cursor: wait;
}

@media (max-width: 768px) {
  .admin-company-assignment-current,
