                    tabIndex={0}
                    onClick={openImageViewer}
                    onKeyDown={(event) => {
                      if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        openImageViewer();
                      }
                    }}
                    aria-label="عرض الصورة بالحجم الكامل"
                  >
                    <img src={activeImage.url} alt={title} />

                    <span className="user-report-modal__image-hint">
