      source.UnableToExecuteAt ||
      report.unableToExecuteAt ||
      report.UnableToExecuteAt ||
      null,
  };

  if (
    statusKey === REPORT_STATUS_API_VALUES.unableToExecute &&
    !result.publicMessage
  ) {
    result.publicMessage =
      result.unableToExecuteReason ||
      'تعذر تنفيذ البلاغ بعد مراجعة الجهة المختصة.';
  }

  return result;
}

