}

.company-notifications-loading span {
  font-size: 0.94rem;
  font-weight: 900;
}

@keyframes companyNotificationsSpin {
  to {
    transform: rotate(360deg);
  }
}

.company-notifications-empty__icon {
  width: 64px;
  height: 64px;
  border-radius: 22px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.company-notifications-empty__icon svg {
  width: 28px;
  height: 28px;
}

.company-notifications-empty h3 {
  margin: 0;
  color: var(--color-text);
  font-size: 1.15rem;
  font-weight: 900;
}

.company-notifications-empty p {
  margin: 0;
  max-width: 420px;
  color: var(--color-subtitle);
  font-size: 0.9rem;
  font-weight: 700;
  line-height: 1.8;
}

.company-notifications-list {
  display: grid;
  gap: 12px;
}

.company-notification-item {
  position: relative;
  display: grid;
  grid-template-columns: auto auto minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
  padding: 16px;
  border: 1.5px solid rgba(2, 95, 72, 0.07);
  border-radius: 22px;
  background: #ffffff;
  box-shadow: 0 12px 26px rgba(2, 95, 72, 0.045);
  direction: rtl;
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base),
    border-color var(--transition-base),
    background var(--transition-base);
}

.company-notification-item:hover {
  transform: translateY(-1px);
  border-color: rgba(2, 95, 72, 0.16);
  box-shadow: 0 18px 34px rgba(2, 95, 72, 0.08);
}

.company-notification-item.is-read {
  background: rgba(248, 250, 252, 0.82);
}

.company-notification-item.is-unread {
  background:
    linear-gradient(90deg, rgba(2, 95, 72, 0.035), transparent 42%),
    #ffffff;
}

.company-notification-item__status {
  display: grid;
  place-items: center;
  width: 12px;
}

.company-notification-item__status-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: rgba(148, 163, 184, 0.7);
}

.company-notification-item.is-unread .company-notification-item__status-dot {
  background: var(--color-primary);
  box-shadow: 0 0 0 6px rgba(2, 95, 72, 0.08);
}

.company-notification-item__icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.company-notification-item--success .company-notification-item__icon {
  background: rgba(34, 197, 94, 0.12);
  color: #15905f;
}

.company-notification-item--warning .company-notification-item__icon {
  background: rgba(245, 158, 11, 0.13);
  color: #c47a00;
}

.company-notification-item--info .company-notification-item__icon {
  background: rgba(59, 130, 246, 0.12);
  color: #2563eb;
}

.company-notification-item--primary .company-notification-item__icon {
  background: rgba(2, 95, 72, 0.1);
  color: var(--color-primary);
}

.company-notification-item--neutral .company-notification-item__icon {
  background: rgba(100, 116, 139, 0.12);
  color: #64748b;
}

.company-notification-item__icon svg {
  width: 21px;
  height: 21px;
}

.company-notification-item__content {
  display: grid;
  gap: 8px;
  min-width: 0;
  text-align: right;
}

.company-notification-item__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
}

.company-notification-item__eyebrow {
  display: inline-flex;
  margin-bottom: 4px;
  color: var(--color-primary);
  font-size: 0.74rem;
  font-weight: 900;
}

.company-notification-item.is-read .company-notification-item__eyebrow {
  color: #94a3b8;
}

.company-notification-item__content h3 {
  margin: 0;
  color: var(--color-text);
  font-size: 1.02rem;
  font-weight: 900;
  line-height: 1.5;
  overflow-wrap: anywhere;
}

.company-notification-item__content p {
  margin: 0;
  color: var(--color-subtitle);
  font-size: 0.9rem;
  font-weight: 700;
  line-height: 1.8;
  overflow-wrap: anywhere;
}

.company-notification-item__time {
  min-width: max-content;
  min-height: 30px;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.06);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  font-weight: 900;
  white-space: nowrap;
}

.company-notification-item__time svg {
  width: 14px;
  height: 14px;
}

.company-notification-item__meta {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 8px;
}

.company-notification-item__meta span {
  min-height: 30px;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.045);
  color: #667085;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  font-weight: 800;
}

.company-notification-item__meta svg {
  width: 14px;
  height: 14px;
  color: var(--color-primary);
}

.company-notification-item__actions {
  display: grid;
  justify-items: stretch;
  gap: 8px;
  min-width: 132px;
}

.company-notification-item__action,
.company-notification-item__delete,
.company-notification-item__read-badge {
  min-height: 40px;
  border-radius: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-family: inherit;
  font-size: 0.82rem;
  font-weight: 900;
}

.company-notification-item__action--read {
  padding: 8px 12px;
  background: var(--color-primary);
  color: #ffffff;
}

.company-notification-item__read-badge {
  padding: 8px 12px;
  background: rgba(34, 197, 94, 0.1);
  color: #13895f;
}

.company-notification-item__read-badge svg {
  width: 15px;
  height: 15px;
}

.company-notification-item__delete {
  padding: 0 12px;
  border: 1px solid rgba(239, 68, 68, 0.12);
  background: rgba(254, 242, 242, 0.8);
  color: #c24141;
}

.company-notification-item__delete svg {
  width: 16px;
  height: 16px;
}

@media (max-width: 1200px) {
  .company-notifications-hero {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 992px) {
  .company-notification-item {
    grid-template-columns: auto auto minmax(0, 1fr);
  }

  .company-notification-item__actions {
    grid-column: 1 / -1;
    grid-template-columns: 1fr auto;
    min-width: 0;
  }

  .company-notification-item__action,
  .company-notification-item__read-badge {
    width: 100%;
  }
}

@media (max-width: 768px) {
  .company-notifications-page {
    gap: 16px;
  }

  .company-notifications-hero,
  .company-notifications-panel {
    padding: 16px;
    border-radius: 22px;
  }

  .company-notifications-hero__content {
    justify-items: stretch;
  }

  .company-notifications-hero__content h2,
  .company-notifications-hero__content p {
    text-align: right;
  }

  .company-notifications-hero__stats {
    grid-template-columns: 1fr;
  }

  .company-notifications-hero__stats article {
    min-height: 88px;
  }

  .company-notifications-toolbar {
    align-items: stretch;
  }

  .company-notifications-toolbar__search {
    flex-basis: 100%;
    min-width: 0;
  }

  .company-notifications-toolbar__actions {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
  }

  .company-notifications-btn {
    width: 100%;
  }

  .company-notifications-filters {
    justify-content: stretch;
  }

  .company-notifications-filter {
    flex: 1 1 calc(50% - 8px);
    justify-content: center;
  }

  .company-notification-item {
    grid-template-columns: auto minmax(0, 1fr);
    align-items: flex-start;
    padding: 14px;
    border-radius: 18px;
  }

  .company-notification-item__status {
    display: none;
  }

  .company-notification-item__icon {
    width: 44px;
    height: 44px;
    border-radius: 14px;
  }

  .company-notification-item__top {
    display: grid;
    gap: 8px;
  }

  .company-notification-item__time {
    justify-self: start;
  }

  .company-notification-item__actions {
    grid-column: 1 / -1;
  }
}

@media (max-width: 480px) {
  .company-notifications-hero,
  .company-notifications-panel {
    padding: 14px;
  }

  .company-notifications-filter {
    flex-basis: 100%;
  }

  .company-notification-item {
    grid-template-columns: 1fr;
  }

  .company-notification-item__icon {
    justify-self: end;
  }

  .company-notification-item__actions {
    grid-template-columns: 1fr;
  }

  .company-notification-item__delete {
    width: 100%;
  }
}
