@keyframes reports-map-user-marker-pulse {
  0% {
    opacity: 0.95;
    transform: scale(0.9);
  }

  100% {
    opacity: 0;
    transform: scale(1.4);
  }
}

.reports-map__popup {
  min-width: 170px;
  display: grid;
  gap: 4px;
