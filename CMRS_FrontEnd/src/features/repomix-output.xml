/* ========================================================================== */
/* Company reports execution workspace - team, start proof and copyable ID    */
/* ========================================================================== */

.company-copyable-report-id,
.company-copyable-report-id * {
  user-select: text !important;
  -webkit-user-select: text !important;
  cursor: text;
}

.company-copyable-report-id[dir='ltr'],
.company-copyable-report-id b[dir='ltr'] {
  direction: ltr;
  unicode-bidi: plaintext;
}

.company-report-table-summary__description {
  max-width: 360px;
  color: var(--color-subtitle);
  font-size: 0.76rem;
  font-weight: 800;
  line-height: 1.65;
