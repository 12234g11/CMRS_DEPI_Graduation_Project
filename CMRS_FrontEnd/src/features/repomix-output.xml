}

.user-profile-info-list__bio {
  display: block !important;
}

.user-profile-info-list__bio p {
  margin: 7px 0 0;
  color: var(--color-text);
  font-size: 0.9rem;
  font-weight: 700;
  line-height: 1.9;
}

/* ===== Form ===== */

.user-profile-form {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.user-profile-form label {
  display: grid;
  gap: 8px;
  min-width: 0;
}

.user-profile-form__full {
  grid-column: 1 / -1;
}

.user-profile-form span {
  color: var(--color-text);
  font-size: 0.86rem;
  font-weight: 900;
  text-align: right;
}

.user-profile-form input,
.user-profile-form textarea {
  width: 100%;
  min-height: 50px;
  padding: 12px 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.14);
  border-radius: 16px;
  background: #ffffff;
  color: var(--color-text);
  font-family: inherit;
  font-size: 0.92rem;
  font-weight: 700;
  text-align: right;
  outline: 0;
  transition:
    border-color var(--transition-base),
    box-shadow var(--transition-base);
}

.user-profile-form textarea {
  resize: vertical;
  min-height: 112px;
}

.user-profile-form input:focus,
.user-profile-form textarea:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4px rgba(2, 95, 72, 0.1);
}

/* ===== Stats ===== */

.user-profile-trust {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 18px;
  align-items: center;
}

.user-profile-trust__circle {
  width: 126px;
  height: 126px;
  border-radius: 50%;
  padding: 10px;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.user-profile-trust__circle > div {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #ffffff;
  display: grid;
  place-items: center;
  align-content: center;
