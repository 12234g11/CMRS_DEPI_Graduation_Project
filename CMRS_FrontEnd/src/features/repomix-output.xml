  color: var(--color-primary);
  font-size: 0.8rem;
  font-weight: 900;
}

.user-reports-stats__grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 14px;
  align-items: stretch;
}

.user-reports-stat-card {
  --stat-accent: #6b5cff;
  --stat-accent-rgb: 107, 92, 255;

  position: relative;
  min-width: 0;
  min-height: 150px;
  overflow: hidden;
  padding: 16px;
  border: 1px solid rgba(var(--stat-accent-rgb), 0.18);
  border-radius: 18px;
  background:
    linear-gradient(145deg, rgba(var(--stat-accent-rgb), 0.095), rgba(255, 255, 255, 0.98) 58%),
    #ffffff;
  box-shadow: 0 9px 22px rgba(15, 23, 42, 0.05);
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease,
    border-color 0.2s ease;
}

.user-reports-stat-card::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 5px;
  height: 100%;
  background: var(--stat-accent);
  opacity: 0.9;
}

.user-reports-stat-card:hover {
  transform: translateY(-3px);
  border-color: rgba(var(--stat-accent-rgb), 0.34);
  box-shadow: 0 15px 32px rgba(15, 23, 42, 0.085);
}

.user-reports-stat-card--total {
  --stat-accent: #6b5cff;
  --stat-accent-rgb: 107, 92, 255;
}

.user-reports-stat-card--warning {
  --stat-accent: #c5ad18;
  --stat-accent-rgb: 197, 173, 24;
}

.user-reports-stat-card--primary,
.user-reports-stat-card--info {
  --stat-accent: #4258d8;
  --stat-accent-rgb: 66, 88, 216;
}

.user-reports-stat-card--success {
  --stat-accent: #2cac61;
  --stat-accent-rgb: 44, 172, 97;
}

.user-reports-stat-card--secondary {
  --stat-accent: #64748b;
  --stat-accent-rgb: 100, 116, 139;
}

.user-reports-stat-card--danger {
