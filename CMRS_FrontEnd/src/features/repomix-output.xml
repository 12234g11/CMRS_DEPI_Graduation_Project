/* =========================
   Report image gallery / preview
========================= */

.admin-report-image-preview {
  position: relative;
  display: block;
  width: calc(100% - 40px);
  padding: 0;
  border: 0;
  cursor: zoom-in;
}

.admin-report-image-preview img {
  transition: transform 220ms ease;
}

.admin-report-image-preview:hover img {
  transform: scale(1.06);
}

.admin-report-image-preview__overlay {
  position: absolute;
  inset: auto 14px 14px 14px;
  min-height: 42px;
  padding: 9px 12px;
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.58);
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 0.82rem;
  font-weight: 900;
  opacity: 0;
  transform: translateY(8px);
  transition:
    opacity 180ms ease,
    transform 180ms ease;
  pointer-events: none;
}

.admin-report-image-preview:hover .admin-report-image-preview__overlay,
.admin-report-image-preview:focus-visible .admin-report-image-preview__overlay {
  opacity: 1;
  transform: translateY(0);
}

.admin-report-images-empty {
  margin: 18px 20px 0;
  padding: 18px;
  border: 1px dashed rgba(2, 95, 72, 0.18);
  border-radius: 14px;
