  .company-dashboard-map-toolbar-header,
  .company-dashboard-map-card__header,
  .company-report-modal__header {
    display: grid;
    text-align: center;
    justify-items: center;
  }

  .company-dashboard-map-toolbar {
    grid-template-columns: 1fr;
  }

  .company-dashboard-map-search,
  .company-dashboard-reset-btn,
  .company-dashboard-filter-icon-btn {
    width: 100%;
  }

  .company-dashboard-map-wrapper {
    padding: 12px;
    min-height: 540px;
  }

  .company-dashboard-map-wrapper .leaflet-container {
    min-height: 540px;
    border-radius: 18px;
  }

  .company-dashboard-selected-report-card {
    top: auto;
    right: 24px;
    left: 24px;
    bottom: 24px;
