      subtitle: 'Admin Feedback',
      value: adminFeedbackCount,
      tone: 'info',
    },
    {
      id: 'assigned',
      title: 'بلاغات جديدة',
      subtitle: 'New Assignments',
      value: assignedCount,
      tone: 'success',
    },
  ];
}
