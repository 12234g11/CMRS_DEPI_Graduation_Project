  gap: 0.75rem;
  margin-bottom: 1rem;
}

.company-notifications-filter-sheet__group h4 {
  margin: 0;
  color: #0f172a;
  font-size: 0.92rem;
  font-weight: 900;
}

.company-notifications-filter-sheet__read-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
}

@media (max-width: 768px) {
  .company-notifications-read-tabs {
    display: none;
  }

  .company-notifications-filter-sheet__read-options .company-notifications-read-tab {
    display: inline-flex;
    width: 100%;
  }
}
/* Notification linked report action */
.company-notification-item__action--view {
  padding: 8px 12px;
  border: 1px solid rgba(2, 95, 72, 0.14);
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
}

.company-notification-item__action--view:hover {
  background: var(--color-primary);
  color: #ffffff;
}

.company-notification-item__action--view svg {
  width: 15px;
  height: 15px;
}

@media (max-width: 992px) {
  .company-notification-item__actions {
    grid-template-columns: 1fr 1fr auto;
  }
}

@media (max-width: 560px) {
  .company-notification-item__actions {
    grid-template-columns: 1fr;
  }

  .company-notification-item__action--view,
  .company-notification-item__delete {
    width: 100%;
  }
}

/* =========================================================
   Notification report details modal
   ========================================================= */
.notification-report-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 99999;
  padding: 24px;
  background: rgba(15, 23, 42, 0.54);
  backdrop-filter: blur(7px);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow-y: auto;
  direction: rtl;
}

.notification-report-modal-backdrop__click-area {
  position: fixed;
  inset: 0;
  border: 0;
  background: transparent;
  cursor: pointer;
}

.notification-report-modal {
  position: relative;
  z-index: 2;
  width: min(980px, 100%);
  max-height: calc(100dvh - 48px);
  border-radius: 28px;
  background: #ffffff;
  box-shadow: 0 28px 80px rgba(15, 23, 42, 0.28);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.notification-report-modal__close {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 5;
  width: 42px;
  height: 42px;
  border: 0;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
  cursor: pointer;
  transition:
    transform var(--transition-base),
    background var(--transition-base);
}

.notification-report-modal__close:hover {
  transform: translateY(-1px);
  background: rgba(2, 95, 72, 0.14);
}

.notification-report-modal__close svg {
  width: 20px;
  height: 20px;
}

.notification-report-modal__header {
  padding: 26px 28px 20px 78px;
  border-bottom: 1px solid rgba(2, 95, 72, 0.08);
  background:
    radial-gradient(circle at top left, rgba(2, 95, 72, 0.1), transparent 32%),
    linear-gradient(135deg, rgba(248, 252, 250, 0.96), rgba(255, 255, 255, 0.98));
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 16px;
  align-items: center;
}

.notification-report-modal__icon {
  width: 58px;
  height: 58px;
  border-radius: 20px;
  background: rgba(2, 95, 72, 0.1);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.notification-report-modal__icon svg {
  width: 28px;
  height: 28px;
}

.notification-report-modal__eyebrow {
  color: var(--color-primary);
  font-size: 0.78rem;
  font-weight: 950;
}

.notification-report-modal__header h3 {
  margin: 4px 0 6px;
  color: var(--color-text);
  font-size: 1.28rem;
  font-weight: 950;
  line-height: 1.5;
}

.notification-report-modal__header p {
  margin: 0;
  color: var(--color-subtitle);
  font-size: 0.9rem;
  font-weight: 800;
  line-height: 1.8;
}

.notification-report-modal__body {
  padding: 22px;
  overflow-y: auto;
  display: grid;
  gap: 16px;
  min-height: 0;
}

.notification-report-modal__state {
  min-height: 220px;
  border: 1.5px dashed rgba(2, 95, 72, 0.18);
  border-radius: 22px;
  background: rgba(248, 252, 249, 0.9);
  color: var(--color-primary);
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 12px;
  text-align: center;
  padding: 24px;
}

.notification-report-modal__state svg {
  width: 32px;
  height: 32px;
}

.notification-report-modal__state > svg:first-child {
  animation: companyNotificationsSpin 1s linear infinite;
}

.notification-report-modal__state--error {
  border-color: rgba(220, 38, 38, 0.22);
  background: rgba(254, 242, 242, 0.9);
  color: #b91c1c;
}

.notification-report-modal__state--error > svg:first-child {
  animation: none;
}

.notification-report-modal__state p {
  margin: 0;
  color: #7f1d1d;
  font-size: 0.9rem;
  font-weight: 800;
  line-height: 1.8;
}

.notification-report-modal__status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.notification-report-modal__status,
.notification-report-modal__report-id,
.notification-report-modal__section-title span {
  min-height: 34px;
  padding: 7px 12px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8rem;
  font-weight: 950;
}

.notification-report-modal__status--primary {
  background: rgba(2, 95, 72, 0.1);
  color: var(--color-primary);
}

.notification-report-modal__status--success {
  background: rgba(34, 197, 94, 0.12);
  color: #15803d;
}

.notification-report-modal__status--warning {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.notification-report-modal__status--danger {
  background: rgba(220, 38, 38, 0.1);
  color: #b91c1c;
}

.notification-report-modal__report-id {
  background: rgba(15, 23, 42, 0.05);
  color: #475569;
}

.notification-report-modal__info-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.notification-report-modal__info-card {
  min-width: 0;
  padding: 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: 18px;
  background: #ffffff;
  box-shadow: 0 10px 24px rgba(15, 23, 42, 0.045);
  display: grid;
  gap: 8px;
}

.notification-report-modal__info-icon {
  width: 36px;
  height: 36px;
  border-radius: 13px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.notification-report-modal__info-icon svg {
  width: 18px;
  height: 18px;
}

.notification-report-modal__info-card span:not(.notification-report-modal__info-icon) {
  color: var(--color-subtitle);
  font-size: 0.76rem;
  font-weight: 900;
}

.notification-report-modal__info-card strong {
  color: var(--color-text);
  font-size: 0.94rem;
  font-weight: 950;
  line-height: 1.6;
  overflow-wrap: anywhere;
}

.notification-report-modal__section {
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: 20px;
  background: #ffffff;
  box-shadow: 0 10px 24px rgba(15, 23, 42, 0.035);
  overflow: hidden;
}

.notification-report-modal__section--warning {
  border-color: rgba(220, 38, 38, 0.16);
  background: rgba(254, 242, 242, 0.7);
}

.notification-report-modal__section--update {
  border-color: rgba(245, 158, 11, 0.18);
  background: rgba(255, 251, 235, 0.78);
}

.notification-report-modal__section-title {
  padding: 16px 18px;
  border-bottom: 1px solid rgba(2, 95, 72, 0.07);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.notification-report-modal__section-title h4 {
  margin: 0;
  color: var(--color-text);
  font-size: 1rem;
  font-weight: 950;
}

.notification-report-modal__section-title p {
  margin: 3px 0 0;
  color: var(--color-subtitle);
  font-size: 0.78rem;
  font-weight: 800;
}

.notification-report-modal__section-title span {
  background: rgba(2, 95, 72, 0.1);
  color: var(--color-primary);
}

.notification-report-modal__description,
.notification-report-modal__empty-text {
  margin: 0;
  padding: 17px 18px;
  color: var(--color-text);
  font-size: 0.94rem;
  font-weight: 800;
  line-height: 1.9;
  overflow-wrap: anywhere;
}

.notification-report-modal__empty-text {
  color: var(--color-subtitle);
}

.notification-report-modal__date-note {
  display: inline-flex;
  margin: 0 18px 18px;
  color: var(--color-primary);
  font-size: 0.78rem;
  font-weight: 900;
}

.notification-report-modal__images-grid {
  padding: 16px 18px 18px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.notification-report-modal__image-link {
  position: relative;
  display: block;
  overflow: hidden;
  border-radius: 16px;
  background: rgba(2, 95, 72, 0.06);
  aspect-ratio: 16 / 10;
}

.notification-report-modal__image-link::after {
  content: 'عرض الصورة';
  position: absolute;
  inset-inline: 10px;
  bottom: 10px;
  min-height: 28px;
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.62);
  color: #fff;
  display: grid;
  place-items: center;
  font-size: 0.74rem;
  font-weight: 900;
  opacity: 0;
  transition: opacity var(--transition-base);
}

.notification-report-modal__image-link:hover::after {
  opacity: 1;
}

.notification-report-modal__image-link img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform var(--transition-base);
}

.notification-report-modal__image-link:hover img {
  transform: scale(1.04);
}

.notification-report-modal__timeline {
  padding: 16px 18px 18px;
  display: grid;
  gap: 12px;
}

.notification-report-modal__timeline-item {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 12px;
  align-items: flex-start;
}

.notification-report-modal__timeline-icon {
  width: 38px;
  height: 38px;
  border-radius: 13px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.notification-report-modal__timeline-icon svg {
  width: 17px;
  height: 17px;
}

.notification-report-modal__timeline-item strong {
  color: var(--color-text);
  font-size: 0.92rem;
  font-weight: 950;
}

.notification-report-modal__timeline-item p {
  margin: 5px 0;
  color: var(--color-subtitle);
  font-size: 0.86rem;
  font-weight: 800;
  line-height: 1.8;
}

.notification-report-modal__timeline-item small {
  color: var(--color-primary);
  font-size: 0.76rem;
  font-weight: 900;
}

@media (max-width: 992px) {
  .notification-report-modal__info-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .notification-report-modal__images-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
  .notification-report-modal-backdrop {
    padding: 14px;
    align-items: flex-start;
  }

  .notification-report-modal {
    max-height: calc(100dvh - 28px);
    border-radius: 24px;
  }

  .notification-report-modal__header {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
    padding: 60px 18px 18px;
  }

  .notification-report-modal__body {
    padding: 16px;
  }

  .notification-report-modal__status-row {
    justify-content: center;
  }

  .notification-report-modal__info-grid,
  .notification-report-modal__images-grid {
    grid-template-columns: 1fr;
  }

  .notification-report-modal__info-card,
  .notification-report-modal__section-title,
  .notification-report-modal__description,
  .notification-report-modal__empty-text {
    text-align: center;
  }

  .notification-report-modal__info-icon {
    margin-inline: auto;
  }

  .notification-report-modal__section-title {
    display: grid;
    justify-items: center;
  }

  .notification-report-modal__timeline-item {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
  }
}

/* Company-specific integration helpers */
.company-notification-item__action {
  text-decoration: none;
  border: 0;
  cursor: pointer;
}

.company-notification-item__delete,
.company-notifications-btn,
.company-notifications-read-tab,
.company-notifications-filter-dropdown__button,
.company-notifications-filter-dropdown__item,
.company-notifications-mobile-filter-btn,
.company-notifications-filter-sheet__option,
.company-notifications-filter-sheet__header button,
.company-notifications-filter-sheet__backdrop {
  font-family: inherit;
}
