        title={isVisible ? 'إخفاء كلمة المرور' : 'إظهار كلمة المرور'}
      >
        {isVisible ? <FiEyeOff size={19} /> : <FiEye size={19} />}
      </button>
    </div>
  );
}

export default PasswordInput;
