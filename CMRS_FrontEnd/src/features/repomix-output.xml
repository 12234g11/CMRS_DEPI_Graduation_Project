.company-reports-state button {
  border: 0;
  border-radius: 999px;
  padding: 8px 14px;
  background: #991b1b;
  color: #fff;
  font: inherit;
  font-size: 13px;
  cursor: pointer;
}

.company-reports-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin-top: 18px;
  flex-wrap: wrap;
}

.company-reports-pagination button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 0;
  border-radius: 999px;
  padding: 10px 18px;
  background: #0f766e;
  color: #fff;
  font: inherit;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.company-reports-pagination button:not(:disabled):hover {
  transform: translateY(-1px);
}

.company-reports-pagination button:disabled {
  cursor: not-allowed;
  opacity: 0.45;
}

.company-reports-pagination span {
  color: #475569;
  font-weight: 800;
}

/* ========================================================================== */
/* Company reports UX refresh - execution flow without ratings or teams       */
/* ========================================================================== */

.company-reports-table {
  min-width: 940px;
  table-layout: auto;
}

.company-reports-table th,
.company-reports-table td {
  text-align: center;
}

.company-reports-table th:first-child,
.company-reports-table td:first-child {
  width: 30%;
}

.company-report-table-summary {
  display: grid;
  justify-items: center;
  gap: 4px;
  text-align: center;
}

.company-report-table-summary__id {
  color: var(--color-primary);
  font-size: 0.72rem;
  font-weight: 950;
}

.company-report-table-summary strong {
  color: var(--color-text);
  line-height: 1.55;
  font-size: 0.9rem;
  font-weight: 950;
}

.company-report-table-summary small {
  color: var(--color-subtitle);
  font-weight: 850;
}

.company-report-table-summary__location {
  margin-top: 3px;
  color: var(--color-subtitle);
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  gap: 5px;
  font-size: 0.74rem !important;
}

.company-report-table-summary__location svg {
  flex: 0 0 auto;
  color: var(--color-primary);
}

.company-report-assigned-date {
  color: var(--color-text);
  font-size: 0.78rem;
  font-weight: 900;
  line-height: 1.7;
}

.company-report-actions {
  justify-content: center;
}

.company-report-start-btn:disabled,
.company-report-upload-btn:disabled,
.company-submit-solution-btn:disabled,
.company-start-work-btn:disabled,
.company-cannot-fix-btn:disabled {
  opacity: 0.58;
  cursor: not-allowed;
  transform: none;
}

/* Details hero */

.company-report-hero {
  position: relative;
  overflow: hidden;
  padding: 24px;
  background:
    radial-gradient(circle at top left, rgba(2, 95, 72, 0.13), transparent 38%),
    linear-gradient(135deg, #ffffff 0%, #f4fbf7 100%);
}

.company-report-hero::after {
  content: '';
  position: absolute;
  inset-inline-end: -70px;
  bottom: -95px;
  width: 230px;
  height: 230px;
  border-radius: 50%;
  background: rgba(2, 95, 72, 0.05);
  pointer-events: none;
}

.company-report-hero__content {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 12px;
}

.company-report-hero__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.company-report-hero__id {
  width: fit-content;
  color: var(--color-primary);
  font-size: 0.82rem;
  font-weight: 950;
}

.company-report-hero h1 {
  max-width: 900px;
  margin: 0;
  color: var(--color-primary);
  font-size: clamp(1.25rem, 2vw, 1.75rem);
  font-weight: 950;
  line-height: 1.5;
}

.company-report-hero p {
  max-width: 920px;
  margin: 0;
  color: var(--color-subtitle);
  font-weight: 850;
  line-height: 1.9;
}

.company-report-hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.company-report-hero__meta span {
  min-height: 36px;
  padding: 7px 11px;
  border: 1px solid rgba(2, 95, 72, 0.09);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.74);
  color: var(--color-text);
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 0.8rem;
  font-weight: 900;
}

.company-report-hero__meta svg {
  color: var(--color-primary);
}

/* Workflow */

.company-report-workflow-card {
  display: grid;
  gap: 18px;
}

.company-report-workflow {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.company-report-workflow article {
  position: relative;
  min-height: 105px;
  padding: 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.1);
  border-radius: 16px;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}

.company-report-workflow article:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 50%;
  inset-inline-start: calc(100% + 2px);
  width: 8px;
  height: 2px;
  background: rgba(2, 95, 72, 0.2);
}

.company-report-workflow article.is-active {
  border-color: rgba(2, 95, 72, 0.55);
  background: rgba(2, 95, 72, 0.045);
  box-shadow: 0 12px 28px rgba(2, 95, 72, 0.1);
  transform: translateY(-2px);
}

.company-report-workflow article.is-completed {
  border-color: rgba(52, 168, 83, 0.3);
  background: rgba(52, 168, 83, 0.06);
}

.company-report-workflow__icon {
  width: 42px;
  height: 42px;
  flex: 0 0 42px;
  border-radius: 13px;
  background: rgba(107, 114, 128, 0.1);
  color: var(--color-subtitle);
  display: grid;
  place-items: center;
}

.company-report-workflow article.is-active .company-report-workflow__icon {
  background: var(--color-primary);
  color: #fff;
}

.company-report-workflow article.is-completed .company-report-workflow__icon {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.company-report-workflow strong,
.company-report-workflow small {
  display: block;
}

.company-report-workflow strong {
  color: var(--color-text);
  font-size: 0.84rem;
  font-weight: 950;
}

.company-report-workflow small {
  margin-top: 4px;
  color: var(--color-subtitle);
  font-size: 0.72rem;
  font-weight: 850;
  line-height: 1.55;
}

.company-report-workflow-returned {
  padding: 12px 14px;
  border-radius: 14px;
  background: rgba(255, 193, 7, 0.16);
  color: #9b7100;
  display: flex;
  align-items: flex-start;
  gap: 9px;
  font-size: 0.82rem;
  font-weight: 900;
  line-height: 1.7;
}

/* Community placeholders - intentionally not connected to the API yet */

.company-community-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.company-community-metrics article {
  min-height: 118px;
  padding: 17px;
  border: 1px solid rgba(2, 95, 72, 0.08);
  border-radius: 18px;
  background: #fff;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  gap: 13px;
}

.company-community-metrics article > span {
  width: 48px;
  height: 48px;
  flex: 0 0 48px;
  border-radius: 15px;
  display: grid;
  place-items: center;
}

.company-community-metrics article.is-followers > span {
  background: rgba(90, 107, 255, 0.12);
  color: #4352db;
}

.company-community-metrics article.is-verified > span {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.company-community-metrics article.is-rejected > span {
  background: rgba(239, 124, 124, 0.14);
  color: #c24a4a;
}

.company-community-metrics small,
.company-community-metrics strong,
.company-community-metrics p {
  display: block;
}

.company-community-metrics small {
  color: var(--color-subtitle);
  font-size: 0.77rem;
  font-weight: 900;
}

.company-community-metrics strong {
  margin-top: 2px;
  color: var(--color-text);
  font-size: 1.45rem;
  font-weight: 950;
}

.company-community-metrics p {
  margin: 2px 0 0;
  color: var(--color-subtitle);
  font-size: 0.7rem;
  font-weight: 800;
}

/* Admin decision */

.company-admin-decision-card {
  border-inline-start: 5px solid rgba(90, 107, 255, 0.55);
}

.company-admin-decision-card.is-accepted {
  border-inline-start-color: #218540;
  background: linear-gradient(135deg, #fff, rgba(52, 168, 83, 0.05));
}

.company-admin-decision-card.is-needs-completion,
.company-admin-decision-card.is-rejected {
  border-inline-start-color: #c88700;
  background: linear-gradient(135deg, #fff, rgba(255, 193, 7, 0.07));
}

.company-admin-decision-card__content {
  margin-top: 14px;
  padding: 16px;
  border-radius: 15px;
  background: rgba(2, 95, 72, 0.045);
}

.company-admin-decision-card__content strong {
  color: var(--color-primary);
  display: block;
  font-size: 1rem;
  font-weight: 950;
}

.company-admin-decision-card__content p {
  margin: 8px 0;
  color: var(--color-text);
  font-weight: 850;
  line-height: 1.85;
}

.company-admin-decision-card__content small {
  color: var(--color-subtitle);
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-weight: 850;
}

/* Action cards and validation */

.company-report-action-card {
  border-color: rgba(2, 95, 72, 0.18);
  box-shadow: 0 14px 34px rgba(2, 95, 72, 0.08);
}

.company-report-secondary-action-card {
  background: #fcfcfc;
}

.company-report-form-field > span b {
  color: #c24a4a;
}

.company-report-form-field > span small {
  color: var(--color-subtitle);
  font-size: 0.72rem;
}

.company-report-form-field input[aria-invalid='true'],
.company-report-form-field textarea[aria-invalid='true'] {
  border-color: rgba(194, 74, 74, 0.7);
  background: rgba(239, 124, 124, 0.035);
}

.company-report-field-counter {
  color: var(--color-subtitle);
  font-size: 0.7rem;
  font-weight: 800;
  text-align: left;
}

.company-report-field-error {
  color: #c24a4a;
  font-size: 0.76rem;
  font-weight: 900;
  line-height: 1.6;
}

.company-report-confirmation {
  padding: 12px 13px;
  border: 1px solid rgba(2, 95, 72, 0.1);
  border-radius: 13px;
  background: rgba(2, 95, 72, 0.035);
  color: var(--color-text);
  display: flex;
  align-items: flex-start;
  gap: 9px;
  font-size: 0.8rem;
  font-weight: 900;
  line-height: 1.6;
  cursor: pointer;
}

.company-report-confirmation input {
  width: 18px;
  height: 18px;
  flex: 0 0 18px;
  margin-top: 2px;
  accent-color: var(--color-primary);
}

.company-solution-required-note {
  padding: 14px;
  border: 1px solid rgba(255, 193, 7, 0.25);
  border-radius: 14px;
  background: rgba(255, 193, 7, 0.13);
  color: #8d6700;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.company-solution-required-note strong {
  display: block;
  font-weight: 950;
}

.company-solution-required-note p {
  margin: 5px 0 0;
  font-size: 0.82rem;
  font-weight: 850;
  line-height: 1.7;
}

.company-start-work-panel {
  padding: 16px;
  border: 1px solid rgba(90, 107, 255, 0.14);
  border-radius: 16px;
  background: rgba(90, 107, 255, 0.04);
  display: grid;
  gap: 13px;
}

.company-start-work-panel > div strong {
  color: #4352db;
  font-weight: 950;
}

.company-start-work-panel > div p {
  margin: 5px 0 0;
  color: var(--color-subtitle);
  font-size: 0.8rem;
  font-weight: 850;
  line-height: 1.65;
}

.company-cannot-fix-section {
  display: grid;
  gap: 12px;
}

.company-cannot-fix-toggle {
  width: 100%;
  min-height: 46px;
  padding: 10px 14px;
  border: 1px solid rgba(194, 74, 74, 0.16);
  border-radius: 14px;
  background: rgba(239, 124, 124, 0.055);
  color: #a93838;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  font-weight: 950;
  text-align: right;
}

.company-cannot-fix-toggle > span {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.company-cannot-fix-toggle > svg {
  transition: transform 0.2s ease;
}

.company-cannot-fix-toggle.is-open > svg {
  transform: rotate(180deg);
}

.company-cannot-fix-form {
  padding: 16px;
  border: 1px solid rgba(194, 74, 74, 0.12);
  border-radius: 16px;
  background: #fff;
}

.company-cannot-fix-warning {
  padding: 11px 12px;
  border-radius: 12px;
  background: rgba(239, 124, 124, 0.08);
  color: #a93838;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 0.78rem;
  font-weight: 900;
  line-height: 1.65;
}

.company-report-form-field input[type='file'] {
  padding: 10px;
  background: #fff;
  cursor: pointer;
}

.company-cannot-fix-images {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 10px;
}

.company-cannot-fix-images article {
  position: relative;
  height: 120px;
  overflow: hidden;
  border-radius: 14px;
}

.company-cannot-fix-images img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.25s ease;
}

.company-cannot-fix-images article:hover img {
  transform: scale(1.07);
}

.company-cannot-fix-images article > div {
  position: absolute;
  inset: 0;
  padding: 8px;
  background: linear-gradient(180deg, transparent 35%, rgba(0, 0, 0, 0.72));
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 7px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.company-cannot-fix-images article:hover > div,
.company-cannot-fix-images article:focus-within > div {
  opacity: 1;
}

.company-cannot-fix-images button {
  min-height: 31px;
  padding: 6px 9px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.95);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.7rem;
  font-weight: 950;
}

/* Persisted response */

.company-company-response-card {
  display: grid;
  gap: 16px;
}

.company-company-response-card__details {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.company-company-response-card__details > div,
.company-company-response-card__reason,
.company-company-response-card__note {
  padding: 13px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.045);
}

.company-company-response-card__details span,
.company-company-response-card__details strong {
  display: block;
}

.company-company-response-card__details span {
  color: var(--color-subtitle);
  font-size: 0.74rem;
  font-weight: 850;
}

.company-company-response-card__details strong {
  margin-top: 4px;
  color: var(--color-text);
  font-size: 0.84rem;
  font-weight: 950;
}

.company-company-response-card__reason {
  background: rgba(239, 124, 124, 0.075);
}

.company-company-response-card__reason strong,
.company-company-response-card__note strong {
  color: var(--color-primary);
  font-weight: 950;
}

.company-company-response-card__reason p,
.company-company-response-card__note p {
  margin: 6px 0 0;
  color: var(--color-text);
  font-weight: 850;
  line-height: 1.8;
}

.company-company-response-card__images h3 {
  margin: 0 0 10px;
  color: var(--color-primary);
  font-size: 0.9rem;
  font-weight: 950;
}

/* All report images: hover zoom + full preview */

.company-report-images-grid {
  margin-top: 16px;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
}

.company-report-image-card {
  position: relative;
  min-height: 170px;
  overflow: hidden;
  border: 1px solid rgba(2, 95, 72, 0.08);
  border-radius: 16px;
  background: rgba(2, 95, 72, 0.04);
  box-shadow: 0 9px 24px rgba(15, 23, 42, 0.08);
}

.company-report-image-card img {
  width: 100%;
  height: 190px;
  border-radius: 0;
  object-fit: cover;
  transition: transform 0.3s ease, filter 0.3s ease;
}

.company-report-image-card:hover img,
.company-report-image-card:focus-within img {
  transform: scale(1.08);
  filter: brightness(0.72);
}

.company-report-image-card__overlay {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.company-report-image-card:hover .company-report-image-card__overlay,
.company-report-image-card:focus-within .company-report-image-card__overlay {
  opacity: 1;
}

.company-report-image-card__overlay button {
  min-height: 40px;
  padding: 8px 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.96);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-weight: 950;
  box-shadow: 0 8px 22px rgba(0, 0, 0, 0.18);
}

.company-report-images-empty {
  width: 100%;
  margin-top: 14px;
  display: flex;
  align-items: center;
  gap: 7px;
}

.company-solution-image-preview {
  height: 145px;
}

.company-solution-image-preview img {
  transition: transform 0.25s ease, filter 0.25s ease;
}

.company-solution-image-preview:hover img,
.company-solution-image-preview:focus-within img {
  transform: scale(1.07);
  filter: brightness(0.72);
}

.company-solution-image-preview__overlay {
  position: absolute;
  inset: 0;
  padding: 9px;
  background: linear-gradient(180deg, transparent 30%, rgba(0, 0, 0, 0.72));
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 7px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.company-solution-image-preview:hover .company-solution-image-preview__overlay,
.company-solution-image-preview:focus-within .company-solution-image-preview__overlay {
  opacity: 1;
}

.company-solution-image-preview .company-solution-image-preview__overlay button {
  position: static;
  width: auto;
  height: auto;
  min-height: 31px;
  padding: 6px 9px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.95);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.7rem;
  font-weight: 950;
}

.company-solution-image-preview .company-solution-image-preview__overlay button:last-child {
  color: #c24a4a;
}

.company-image-preview-backdrop {
  position: fixed;
  inset: 0;
  z-index: 100000;
  padding: 24px;
  background: rgba(5, 12, 19, 0.82);
  backdrop-filter: blur(6px);
  display: grid;
  place-items: center;
}

.company-image-preview-modal {
  width: min(1100px, 96vw);
  max-height: 92vh;
  border-radius: 20px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 25px 80px rgba(0, 0, 0, 0.38);
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
}

.company-image-preview-modal header {
  min-height: 58px;
  padding: 10px 14px;
  border-bottom: 1px solid rgba(2, 95, 72, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.company-image-preview-modal header > div {
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.company-image-preview-modal header button {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  background: rgba(239, 124, 124, 0.1);
  color: #c24a4a;
  display: grid;
  place-items: center;
}

.company-image-preview-modal__body {
  min-height: 0;
  padding: 14px;
  overflow: auto;
  background: #111827;
  display: grid;
  place-items: center;
}

.company-image-preview-modal__body img {
  display: block;
  max-width: 100%;
  max-height: calc(92vh - 88px);
  object-fit: contain;
}

/* Status-only cards */

.company-report-waiting-card,
.company-report-resolved-card {
  display: flex;
  align-items: flex-start;
  gap: 13px;
}

.company-report-waiting-card > svg,
.company-report-resolved-card > svg {
  width: 42px;
  height: 42px;
  flex: 0 0 42px;
  padding: 10px;
  border-radius: 14px;
}

.company-report-waiting-card {
  background: rgba(255, 193, 7, 0.08);
}

.company-report-waiting-card > svg {
  background: rgba(255, 193, 7, 0.18);
  color: #a97700;
}

.company-report-resolved-card {
  background: rgba(52, 168, 83, 0.07);
}

.company-report-resolved-card > svg {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.company-report-waiting-card h2,
.company-report-resolved-card h2 {
  margin: 0;
  color: var(--color-primary);
  font-size: 1rem;
  font-weight: 950;
}

.company-report-waiting-card p,
.company-report-resolved-card p {
  margin: 6px 0 0;
  color: var(--color-subtitle);
  font-weight: 850;
  line-height: 1.75;
}

