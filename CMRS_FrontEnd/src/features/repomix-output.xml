  padding: 8px 16px;
  border-radius: 999px;
  background: var(--color-primary);
  color: #fff;
  font-weight: 950;
  white-space: nowrap;
}

/* Toolbar */

.company-reports-card,
.company-report-details-card,
.company-reports-solution-panel {
  border-radius: 22px;
  background: #fff;
  box-shadow: var(--shadow-sm);
}

.company-reports-card {
  overflow: visible;
}

.company-reports-toolbar {
  position: relative;
  z-index: 50;
  display: grid;
  grid-template-columns: minmax(260px, 1.3fr) minmax(160px, 0.8fr) minmax(160px, 0.8fr) auto auto;
  gap: 10px;
  overflow: visible;
}

.company-reports-search {
  min-height: 44px;
  padding: 0 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.14);
  border-radius: 14px;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 10px;
}

.company-reports-search svg {
  color: var(--color-primary);
  width: 18px;
  height: 18px;
}

.company-reports-search input {
  width: 100%;
  border: 0;
  outline: 0;
  color: var(--color-text);
  font-weight: 850;
}

.company-reports-filter-btn,
.company-reports-reset-btn {
  min-height: 44px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-weight: 950;
}

.company-reports-filter-btn {
  width: 48px;
}

.company-reports-reset-btn {
  padding: 8px 13px;
}

/* Filter Select */

.company-reports-filter-select {
  position: relative;
  z-index: 60;
}

.company-reports-filter-select.is-open {
  z-index: 999;
}

.company-reports-filter-select__button {
  width: 100%;
  min-height: 44px;
  padding: 0 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.14);
  border-radius: 14px;
  background: #fff;
  color: var(--color-text);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  font-weight: 950;
}

.company-reports-filter-select__button svg {
  color: var(--color-primary);
  transition: transform 0.2s ease;
}

.company-reports-filter-select__button.is-open svg {
  transform: rotate(180deg);
}

.company-reports-filter-select__menu {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  left: 0;
  margin: 0;
  padding: 8px;
  list-style: none;
  border: 1.5px solid rgba(2, 95, 72, 0.14);
  border-radius: 16px;
  background: #fff;
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.16);
  display: grid;
  gap: 6px;
  max-height: 280px;
  overflow-y: auto;
  direction: rtl;
  z-index: 9999;
}

.company-reports-filter-select__menu li {
  list-style: none;
}

.company-reports-filter-select__option {
  width: 100%;
  min-height: 40px;
  padding: 8px 12px;
  border: 0;
  border-radius: 12px;
  background: transparent;
  color: var(--color-text);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  font-size: 0.86rem;
  font-weight: 900;
  text-align: right;
  cursor: pointer;
}

.company-reports-filter-select__option:hover,
.company-reports-filter-select__option.is-active {
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
}

/* Flow note */

.company-reports-flow-note {
  margin-bottom: 14px;
  padding: 12px 14px;
  border-radius: 14px;
  background: rgba(255, 193, 7, 0.14);
  color: #9b7100;
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 0.82rem;
  font-weight: 900;
  line-height: 1.7;
}

/* Table */

.company-reports-table-wrap {
  width: 100%;
  overflow-x: auto;
}

.company-reports-table {
  width: 100%;
  min-width: 1120px;
  border-collapse: collapse;
}

.company-reports-table th {
  padding: 16px 14px;
  background: #f3f4f4;
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 950;
  white-space: nowrap;
}

.company-reports-table td {
  padding: 15px 14px;
  border-bottom: 1px solid rgba(2, 95, 72, 0.06);
  color: var(--color-text);
  font-size: 0.84rem;
  font-weight: 850;
  vertical-align: middle;
}

.company-reports-table tr.is-highlighted td {
  background: rgba(2, 95, 72, 0.06);
}

.company-reports-table td:first-child strong {
  display: block;
  color: var(--color-text);
  font-weight: 950;
}

.company-reports-table td:first-child span {
  margin-top: 4px;
  display: block;
  color: var(--color-subtitle);
  font-size: 0.75rem;
}

.company-report-rating {
  color: #b4d000;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-weight: 950;
}

.company-report-status,
.company-report-priority,
.company-report-admin-review,
.company-report-team-pill,
.company-report-muted,
.company-report-waiting-pill {
  min-height: 30px;
  padding: 6px 11px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 0.76rem;
  font-weight: 950;
  white-space: nowrap;
}

.company-report-status--success,
.company-report-priority--success,
.company-report-admin-review.is-success {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.company-report-status--warning,
.company-report-priority--warning,
.company-report-admin-review.is-warning {
  background: rgba(255, 193, 7, 0.18);
  color: #b17800;
}

.company-report-status--danger,
.company-report-priority--danger {
  background: rgba(239, 124, 124, 0.14);
  color: #c24a4a;
}

.company-report-status--info {
  background: rgba(90, 107, 255, 0.12);
  color: #4352db;
}

.company-report-admin-review {
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
}

.company-report-team-pill {
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
}

.company-report-muted {
  background: rgba(107, 114, 128, 0.1);
  color: var(--color-subtitle);
}

.company-report-waiting-pill {
  background: rgba(255, 193, 7, 0.18);
  color: #b17800;
}

.company-report-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.company-report-view-btn,
.company-report-assign-btn,
.company-report-start-btn,
.company-report-upload-btn {
  min-height: 34px;
  padding: 7px 10px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 0.76rem;
  font-weight: 950;
  white-space: nowrap;
}

.company-report-view-btn {
  background: var(--color-primary);
  color: #fff;
}

.company-report-assign-btn {
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
}

.company-report-start-btn {
  background: rgba(90, 107, 255, 0.12);
  color: #4352db;
}

.company-report-upload-btn {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.company-report-assign-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

/* Solution panel */

.company-reports-solution-panel {
  padding: 18px;
  display: grid;
  gap: 14px;
}

.company-reports-solution-panel__close {
  width: fit-content;
  min-height: 38px;
  padding: 7px 13px;
  border-radius: 999px;
  background: rgba(239, 124, 124, 0.1);
  color: #c24a4a;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-weight: 950;
}

/* Details */

.company-report-back-link {
  width: fit-content;
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-weight: 950;
}

.company-report-details-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(300px, 0.65fr);
  gap: 18px;
}

.company-report-details-main,
.company-report-details-side {
  display: grid;
  align-content: start;
  gap: 18px;
}

.company-report-details-card {
  padding: 18px;
  border: 1px solid rgba(2, 95, 72, 0.08);
}

.company-report-details-header h2 {
  margin: 14px 0 8px;
  color: var(--color-primary);
  font-size: 1.25rem;
  font-weight: 950;
}

.company-report-details-header p {
  margin: 0;
  color: var(--color-subtitle);
  line-height: 1.8;
  font-weight: 850;
}

.company-report-section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.company-report-section-header h2 {
  margin: 0;
  color: var(--color-primary);
  font-size: 1rem;
  font-weight: 950;
}

.company-report-section-header p {
  margin: 5px 0 0;
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 850;
}

.company-report-section-header > span {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.company-report-images-grid {
  margin-top: 16px;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.company-report-images-grid img {
  width: 100%;
  height: 170px;
  border-radius: 16px;
  object-fit: cover;
}

.company-admin-review-box {
  margin-top: 14px;
  padding: 14px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.06);
}

.company-admin-review-box.is-needs_completion {
  background: rgba(255, 193, 7, 0.16);
  color: #9b7100;
}

.company-admin-review-box.is-accepted {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.company-admin-review-box strong {
  display: block;
  font-weight: 950;
}

.company-admin-review-box p {
  margin: 7px 0;
  line-height: 1.7;
  font-weight: 850;
}

.company-admin-review-box small {
  font-weight: 850;
}

/* Forms */

.company-solution-form,
.company-status-form,
.company-cannot-fix-form {
  display: grid;
  gap: 14px;
}

.company-report-form-field {
  display: grid;
  gap: 8px;
  color: var(--color-subtitle);
  font-size: 0.86rem;
  font-weight: 900;
}

.company-report-form-field input,
.company-report-form-field textarea,
.company-report-form-field select {
  width: 100%;
  padding: 12px 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.16);
  border-radius: 14px;
  color: var(--color-text);
  font-weight: 850;
  outline: none;
}

.company-report-form-field textarea {
  resize: vertical;
}

.company-report-form-field input:focus,
.company-report-form-field textarea:focus,
.company-report-form-field select:focus {
  border-color: rgba(2, 95, 72, 0.55);
  box-shadow: 0 8px 20px rgba(2, 95, 72, 0.08);
}

.company-report-form-error {
  margin: 0;
  color: #c24a4a;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 0.82rem;
  font-weight: 950;
}

.company-submit-solution-btn,
.company-start-work-btn,
.company-cannot-fix-btn {
  min-height: 44px;
  padding: 10px 14px;
  border-radius: 14px;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-weight: 950;
}

.company-submit-solution-btn {
  background: #218540;
}

.company-start-work-btn {
  background: #4352db;
}

.company-cannot-fix-btn {
  background: #c24a4a;
}

.company-current-status-box {
  padding: 14px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.06);
  display: grid;
  gap: 4px;
}

.company-current-status-box span {
  color: var(--color-subtitle);
  font-size: 0.78rem;
  font-weight: 850;
}

.company-current-status-box strong {
  color: var(--color-primary);
  font-weight: 950;
}

.company-solution-form__hint,
.company-solution-form__images-hint {
  margin: 0;
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 850;
}

.company-solution-form__images-hint {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* Side */

.company-report-info-list {
  display: grid;
  gap: 10px;
}

.company-report-info-list > div {
  padding: 12px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.04);
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 4px 8px;
}

.company-report-info-list svg {
  color: var(--color-primary);
  grid-row: span 2;
  margin-top: 4px;
}

.company-report-info-list span {
  color: var(--color-subtitle);
  font-size: 0.76rem;
  font-weight: 850;
}

.company-report-info-list strong {
  color: var(--color-text);
  font-size: 0.84rem;
  font-weight: 950;
}

.company-assigned-team-box,
.company-reporter-box {
  margin-top: 14px;
  padding: 14px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.05);
}

.company-assigned-team-box strong {
  color: var(--color-primary);
  display: block;
  font-weight: 950;
}

.company-assigned-team-box p {
  margin: 6px 0 12px;
  color: var(--color-subtitle);
  font-weight: 850;
}

.company-assigned-team-box button {
  min-height: 38px;
  padding: 8px 12px;
  border-radius: 999px;
  background: var(--color-primary);
  color: #fff;
  font-weight: 950;
}

.company-assigned-team-box button:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

.company-reporter-box {
  display: flex;
  align-items: center;
  gap: 10px;
}

.company-reporter-box svg {
  color: var(--color-primary);
}

.company-reporter-box strong,
.company-reporter-box span {
  display: block;
}

.company-reporter-box strong {
  color: var(--color-text);
  font-weight: 950;
}

.company-reporter-box span {
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 850;
}

.company-report-timeline {
  margin-top: 14px;
  display: grid;
  gap: 10px;
}

.company-report-timeline article {
  padding: 12px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.04);
}

.company-report-timeline strong {
  color: var(--color-text);
  display: block;
  font-size: 0.86rem;
  font-weight: 950;
}

.company-report-timeline p {
  margin: 5px 0;
  color: var(--color-subtitle);
  line-height: 1.6;
  font-size: 0.78rem;
  font-weight: 850;
}

.company-report-timeline small {
  color: var(--color-primary);
  font-size: 0.72rem;
  font-weight: 900;
}

/* Modal */

.company-modal-backdrop {
  position: fixed;
  inset: 0;
  padding: 24px;
  background: rgba(15, 23, 42, 0.42);
  backdrop-filter: blur(8px);
  display: grid;
  place-items: center;
  z-index: 99999;
  overflow-y: auto;
}

.company-modal {
  width: min(720px, 100%);
  max-height: calc(100dvh - 48px);
  overflow-y: auto;
  border-radius: 24px;
  background: #fff;
  padding: 22px;
  position: relative;
  box-shadow: 0 26px 70px rgba(15, 23, 42, 0.24);
}

.company-modal__close {
  position: absolute;
  top: 14px;
  left: 14px;
  width: 38px;
  height: 38px;
  border-radius: 999px;
  background: rgba(239, 124, 124, 0.1);
  color: #c24a4a;
  display: grid;
  place-items: center;
}

.company-modal__header {
  display: flex;
  gap: 12px;
  align-items: center;
}

.company-modal__icon {
  width: 46px;
  height: 46px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.company-modal__header h2 {
  margin: 0;
  color: var(--color-primary);
  font-size: 1.15rem;
  font-weight: 950;
}

.company-modal__header p {
  margin: 5px 0 0;
  color: var(--color-subtitle);
  font-weight: 850;
}

.company-assign-report-summary {
  margin-top: 18px;
  padding: 14px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.05);
  display: grid;
  gap: 5px;
}

.company-assign-report-summary strong {
  color: var(--color-text);
  font-weight: 950;
}

.company-assign-report-summary span {
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 850;
}

.company-technicians-list {
  margin-top: 16px;
  display: grid;
  gap: 10px;
}

.company-technician-card {
  width: 100%;
  padding: 13px;
  border: 1.5px solid rgba(2, 95, 72, 0.1);
  border-radius: 16px;
  background: #fff;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 12px;
  text-align: right;
}

.company-technician-card.is-selected {
  border-color: rgba(2, 95, 72, 0.55);
  background: rgba(2, 95, 72, 0.05);
}

.company-technician-card__icon {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.company-technician-card strong {
  color: var(--color-text);
  display: block;
  font-weight: 950;
}

.company-technician-card p {
  margin: 4px 0;
  color: var(--color-subtitle);
  font-size: 0.8rem;
  font-weight: 850;
}

.company-technician-card small {
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.75rem;
  font-weight: 850;
}

.company-technician-card__badge {
  min-height: 28px;
  padding: 5px 9px;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 950;
}

.company-technician-card__badge.is-available {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.company-technician-card__badge.is-busy {
  background: rgba(255, 193, 7, 0.18);
  color: #b17800;
}

.company-modal__actions {
  margin-top: 18px;
  display: flex;
  justify-content: center;
  gap: 10px;
}

.company-modal-cancel-btn,
.company-modal-submit-btn {
  min-height: 42px;
  padding: 9px 16px;
  border-radius: 14px;
  font-weight: 950;
}

.company-modal-cancel-btn {
  background: rgba(107, 114, 128, 0.1);
  color: var(--color-subtitle);
}

.company-modal-submit-btn {
  background: var(--color-primary);
  color: #fff;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

/* Responsive */

@media (max-width: 1100px) {
  .company-reports-toolbar {
    grid-template-columns: 1fr 1fr;
  }

  .company-reports-filter-btn,
  .company-reports-reset-btn {
    width: 100%;
  }

  .company-report-details-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .company-reports-inbox-summary {
    display: grid;
    justify-items: center;
    text-align: center;
    padding: 18px 16px;
  }

  .company-reports-inbox-summary button {
    width: min(100%, 260px);
  }

  .company-reports-toolbar {
    grid-template-columns: 1fr;
  }

  .company-reports-search,
  .company-reports-filter-btn,
  .company-reports-reset-btn {
    width: 100%;
  }

  .company-report-images-grid {
    grid-template-columns: 1fr;
  }

  .company-report-images-grid img {
    height: 160px;
  }

  .company-report-details-card {
    padding: 16px;
  }

  .company-report-section-header {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .company-modal-backdrop {
    padding: 16px 12px;
    align-items: start;
  }

  .company-modal {
    padding: 20px 16px;
  }

  .company-modal__header {
    display: grid;
    justify-items: center;
    text-align: center;
    padding-top: 34px;
  }

  .company-technician-card {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
  }

  .company-modal__actions {
    display: grid;
  }

  .company-modal-cancel-btn,
  .company-modal-submit-btn {
    width: 100%;
    justify-content: center;
  }
}
/* Smooth scroll target for solution panel */

.company-reports-solution-panel {
  scroll-margin-top: 96px;
}

/* Keep dropdowns above the table/card */

.company-reports-card,
.company-reports-card .dashboard-section-card__header,
.company-reports-card .dashboard-section-card__body,
.company-reports-card .dashboard-section-card__action {
  overflow: visible;
}

.company-reports-toolbar {
  position: relative;
  z-index: 120;
  overflow: visible;
}

/* Enhanced reports dropdown style */

.company-reports-filter-select {
  position: relative;
  z-index: 130;
}

.company-reports-filter-select.is-open {
  z-index: 9999;
}

.company-reports-filter-select__button {
  width: 100%;
