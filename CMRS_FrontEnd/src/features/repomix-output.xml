/* =========================================================
   Professional Reports Summary Cards
   Added for reports overview cards with icons
   ========================================================= */

.admin-reports-stats-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 14px;
  direction: rtl;
  margin-bottom: 18px;
}

.admin-report-stat-card {
  position: relative;
  min-height: 112px;
  padding: 18px;
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: 20px;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(250, 252, 251, 0.98));
  box-shadow:
    0 10px 26px rgba(15, 23, 42, 0.05),
    inset 0 1px 0 rgba(255, 255, 255, 0.75);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  transition:
    transform var(--transition-base),
    box-shadow var(--transition-base),
    border-color var(--transition-base);
}

.admin-report-stat-card::before {
  content: "";
  position: absolute;
  inset-block: 0;
  inset-inline-start: 0;
  width: 5px;
  background: var(--stat-color);
  opacity: 0.9;
}

.admin-report-stat-card::after {
  content: "";
  position: absolute;
  top: -34px;
  left: -34px;
  width: 92px;
  height: 92px;
  border-radius: 50%;
  background: var(--stat-soft);
  opacity: 0.75;
}

.admin-report-stat-card:hover {
  transform: translateY(-3px);
  border-color: rgba(2, 95, 72, 0.18);
  box-shadow:
    0 16px 34px rgba(15, 23, 42, 0.08),
    0 8px 18px rgba(2, 95, 72, 0.08);
}

.admin-report-stat-card__content {
  position: relative;
  z-index: 2;
  min-width: 0;
  display: grid;
  gap: 8px;
  text-align: right;
}

.admin-report-stat-card__content span {
  color: #74827d;
  font-size: 0.82rem;
  font-weight: 900;
  line-height: 1.5;
}

.admin-report-stat-card__content strong {
  color: #101828;
  font-size: 1.8rem;
  font-weight: 950;
  line-height: 1;
  letter-spacing: -0.04em;
}

.admin-report-stat-card__icon {
  position: relative;
  z-index: 2;
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: var(--stat-soft);
  color: var(--stat-color);
  display: grid;
  place-items: center;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1px rgba(2, 95, 72, 0.06);
}

.admin-report-stat-card__icon svg {
  width: 23px;
  height: 23px;
  stroke-width: 2.4;
}

.admin-report-stat-card--primary {
  --stat-color: #025f48;
  --stat-soft: rgba(2, 95, 72, 0.1);
}

.admin-report-stat-card--warning {
  --stat-color: #c98700;
  --stat-soft: rgba(255, 193, 7, 0.18);
}

.admin-report-stat-card--purple {
  --stat-color: #6d5dfc;
  --stat-soft: rgba(109, 93, 252, 0.12);
}

.admin-report-stat-card--blue {
  --stat-color: #2563eb;
  --stat-soft: rgba(37, 99, 235, 0.12);
}

.admin-report-stat-card--info {
  --stat-color: #0891b2;
  --stat-soft: rgba(8, 145, 178, 0.12);
}

.admin-report-stat-card--success {
  --stat-color: #218540;
  --stat-soft: rgba(52, 168, 83, 0.16);
}

.admin-report-stat-card--danger {
  --stat-color: #d64545;
  --stat-soft: rgba(239, 124, 124, 0.16);
