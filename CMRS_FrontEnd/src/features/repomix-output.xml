  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 10px;
}

.company-start-team-required > svg {
  width: 20px;
  height: 20px;
}

.company-start-team-required strong {
  color: #805e00 !important;
  display: block;
}

.company-start-team-required p {
  margin: 2px 0 0 !important;
  color: #967000 !important;
  font-size: 0.74rem !important;
}

.company-start-team-required button {
  min-height: 37px;
  padding: 7px 11px;
  border-radius: 10px;
  background: #9c7400;
  color: #fff;
  font: inherit;
  font-size: 0.73rem;
  font-weight: 950;
