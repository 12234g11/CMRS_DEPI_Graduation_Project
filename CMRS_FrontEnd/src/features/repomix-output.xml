    background var(--transition-base),
    color var(--transition-base),
    border-color var(--transition-base);
}

.company-notifications-filter:hover {
  transform: translateY(-1px);
  border-color: rgba(2, 95, 72, 0.22);
}

.company-notifications-filter strong {
  min-width: 26px;
  height: 26px;
  padding: 0 8px;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.07);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.78rem;
  font-weight: 950;
}

.company-notifications-filter.is-active {
