  font-weight: 900;
}

.user-reports-page .user-dashboard-map-popup__status--info,
.user-reports-page .user-dashboard-map-popup__status--primary {
  background: rgba(66, 88, 216, 0.11);
  color: #3346b5;
}

.user-reports-page .user-dashboard-map-popup__status--success {
  background: rgba(44, 172, 97, 0.11);
  color: #21864b;
}

.user-reports-page .user-dashboard-map-popup__status--secondary {
  background: rgba(100, 116, 139, 0.12);
  color: #526176;
}

.user-reports-page .user-dashboard-map-popup__status--danger {
  background: rgba(220, 53, 69, 0.1);
  color: #b32736;
}

.user-reports-page .user-dashboard-map-popup__actions .user-dashboard-map-popup__visibility-btn {
  border-color: rgba(100, 116, 139, 0.22);
  background: rgba(100, 116, 139, 0.08);
  color: #526176;
}

/* Local fallback for the fifth grouped status tone. */
.user-reports-page .dashboard-badge--secondary,
.user-report-modal .dashboard-badge--secondary {
  border: 1px solid rgba(100, 116, 139, 0.2);
  background: rgba(100, 116, 139, 0.12);
  color: #526176;
}

@media (max-width: 1320px) {
  .user-reports-stats__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 1100px) {
  .user-dashboard-map-card__header {
    align-items: stretch;
  }

  .user-dashboard-map-card__actions,
  .user-reports-map-legend {
    width: 100%;
    max-width: none;
  }
}

@media (max-width: 860px) {
  .user-reports-stats__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .user-reports-stat-card--with-stages {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .user-reports-stat-card__stages {
    padding-top: 14px;
    padding-inline-start: 0;
    border-top: 1px dashed rgba(var(--stat-accent-rgb), 0.3);
    border-inline-start: 0;
  }
}

@media (max-width: 680px) {
  .user-reports-stats {
    padding: 16px;
    border-radius: 20px;
  }

  .user-reports-stats__header {
    display: grid;
    gap: 10px;
  }

  .user-reports-stats__badge {
    justify-self: start;
  }

  .user-reports-stats__grid {
    grid-template-columns: 1fr;
  }

  .user-reports-stat-card,
  .user-reports-stat-card--with-stages {
    min-height: 0;
  }

  .user-reports-stat-card--with-stages {
    padding: 16px;
  }

  .user-reports-stat-card__stage-list {
    gap: 6px;
  }

  .user-reports-map-legend__items {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
  }

  .user-reports-map-legend__item {
    min-width: 0;
  }

  .user-reports-map-legend__note {
    padding: 10px;
  }

  .user-reports-map-hidden-panel {
    margin-inline: 10px;
    padding: 12px;
  }

  .user-reports-map-hidden-panel__header,
  .user-reports-map-visibility-control {
    align-items: stretch;
    flex-direction: column;
  }

  .user-reports-map-hidden-panel__header > button,
  .user-reports-map-visibility-control > button {
    justify-content: center;
  }

  .user-reports-map-hidden-panel__list {
    display: grid;
    grid-template-columns: 1fr;
  }

  .user-reports-map-hidden-panel__list button {
    width: 100%;
    max-width: none;
  }
}

@media (max-width: 390px) {
  .user-reports-map-legend__items {
    grid-template-columns: 1fr;
  }
}


/* ===== Public execution decision card ===== */
.user-report-modal__execution-outcome {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 14px;
  border: 1px solid transparent;
  border-radius: 16px;
  line-height: 1.75;
}

.user-report-modal__execution-outcome-icon {
  display: grid;
  place-items: center;
  flex: 0 0 40px;
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.72);
}

.user-report-modal__execution-outcome strong {
  display: block;
  margin-bottom: 4px;
}

.user-report-modal__execution-outcome p {
  margin: 0;
}

.user-report-modal__execution-outcome small {
  display: block;
  margin-top: 6px;
  opacity: 0.78;
}

.user-report-modal__execution-outcome.is-unable {
  color: #4b5563;
  border-color: rgba(100, 116, 139, 0.23);
  background: rgba(241, 245, 249, 0.92);
}

.user-report-modal__execution-outcome.is-reassigned {
  color: #1e3a8a;
  border-color: rgba(37, 99, 235, 0.2);
  background: rgba(239, 246, 255, 0.92);
}

.user-report-modal__execution-outcome.is-pending {
  color: #5b21b6;
  border-color: rgba(124, 58, 237, 0.18);
  background: rgba(245, 243, 255, 0.92);
}

.user-report-modal__execution-outcome.is-completion {
  color: #92400e;
  border-color: rgba(217, 119, 6, 0.2);
  background: rgba(255, 251, 235, 0.92);
}

@media (max-width: 520px) {
  .user-report-modal__execution-outcome {
    text-align: center;
    align-items: center;
    flex-direction: column;
  }
}
