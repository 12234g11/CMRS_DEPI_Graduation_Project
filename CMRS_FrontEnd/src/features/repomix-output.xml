  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
}

.reports-map__user-marker::after {
  content: '';
  position: absolute;
  inset: -10px;
  border-radius: 50%;
  border: 2px solid rgba(47, 128, 237, 0.25);
  animation: reports-map-user-marker-pulse 1.6s ease-out infinite;
}

@keyframes reports-map-marker-pulse {
  0% {
    opacity: 0.9;
    transform: scale(0.95);
  }

  100% {
    opacity: 0;
    transform: scale(1.35);
