}

.company-start-proof-upload__actions button,
.company-cannot-fix-upload-btn {
  min-height: 37px;
  padding: 7px 11px;
  border: 1px solid rgba(2, 95, 72, 0.16);
  border-radius: 10px;
  background: rgba(2, 95, 72, 0.075);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font: inherit;
  font-size: 0.72rem;
  font-weight: 950;
  cursor: pointer;
}

.company-start-images-preview {
