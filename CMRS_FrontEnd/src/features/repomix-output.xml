}

.company-assigned-team-panel__content p span {
  margin-inline-start: 10px;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}

.company-assigned-team-panel > button {
  min-height: 42px;
  padding: 8px 14px;
  border-radius: 12px;
  background: var(--color-primary);
