/* Highlight report opened from notification */
.user-reports-table tbody tr.dashboard-table__row--highlighted {
  position: relative;
  background: linear-gradient(90deg, rgba(2, 95, 72, 0.12), rgba(255, 255, 255, 0.96));
  box-shadow: inset 4px 0 0 var(--color-primary), 0 0 0 2px rgba(2, 95, 72, 0.18);
  animation: userReportNotificationPulse 1.4s ease-in-out 3;
}

.user-reports-table tbody tr.dashboard-table__row--highlighted td {
  border-top-color: rgba(2, 95, 72, 0.22);
  border-bottom-color: rgba(2, 95, 72, 0.22);
}

.user-report-modal__detail-card--rejection {
  border-color: rgba(220, 38, 38, 0.2);
  background: linear-gradient(180deg, rgba(254, 242, 242, 0.96), #ffffff);
  box-shadow: 0 12px 28px rgba(220, 38, 38, 0.08);
}

.user-report-modal__detail-card--rejection .user-report-modal__detail-label,
.user-report-modal__detail-card--rejection .user-report-modal__detail-label svg {
  color: #dc2626;
}

.user-report-modal__detail-card--rejection .user-report-modal__detail-value {
  color: #991b1b;
}

@keyframes userReportNotificationPulse {
  0%, 100% {
    box-shadow: inset 4px 0 0 var(--color-primary), 0 0 0 2px rgba(2, 95, 72, 0.18);
  }

  50% {
    box-shadow: inset 4px 0 0 var(--color-primary), 0 0 0 7px rgba(2, 95, 72, 0.12);
  }
}

/* ============================= */
/* Engagement counters + table centering */
/* ============================= */

.user-report-modal__engagement-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.user-report-modal__engagement-grid .user-report-modal__summary-card {
  min-height: 118px;
}

.user-report-modal__engagement-grid .user-report-modal__summary-label {
  justify-content: center;
}

.user-report-modal__engagement-grid .user-report-modal__summary-label svg {
  width: 21px;
  height: 21px;
}

.user-report-modal__engagement-grid .user-report-modal__summary-value strong {
  display: block;
  color: var(--color-primary);
  font-size: 1.35rem;
  font-weight: 950;
  line-height: 1;
}

.user-reports-table__report-cell {
  text-align: center;
}

.user-reports-table__report-summary {
  justify-items: center;
  text-align: center;
}

.user-reports-table__report-summary strong {
  margin-inline: auto;
  text-align: center;
}

.user-reports-table__report-summary span {
  text-align: center;
}

@media (max-width: 640px) {
  .user-report-modal__engagement-grid {
    grid-template-columns: 1fr;
  }
}

/* =========================================================
   User reports statistics — API: /api/Report/user/stats
   ========================================================= */

.user-reports-stats {
  padding: 22px;
  border: 1.5px solid rgba(2, 95, 72, 0.1);
  border-radius: 24px;
  background:
    radial-gradient(circle at top right, rgba(2, 95, 72, 0.07), transparent 34%),
    #ffffff;
  box-shadow: 0 12px 34px rgba(2, 95, 72, 0.07);
  direction: rtl;
}

.user-reports-stats__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 18px;
}

.user-reports-stats__header h2 {
  margin: 0;
  color: var(--color-primary);
  font-size: 1.28rem;
  font-weight: 950;
  line-height: 1.3;
}

.user-reports-stats__header p {
  max-width: 760px;
  margin: 7px 0 0;
  color: var(--color-subtitle);
  font-size: 0.9rem;
  font-weight: 750;
  line-height: 1.8;
}

.user-reports-stats__badge {
  min-width: max-content;
  padding: 8px 13px;
  border: 1px solid rgba(2, 95, 72, 0.12);
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.07);
  color: var(--color-primary);
  font-size: 0.8rem;
  font-weight: 900;
}

.user-reports-stats__grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 14px;
  align-items: stretch;
}

.user-reports-stat-card {
  --stat-accent: #6b5cff;
  --stat-accent-rgb: 107, 92, 255;

  position: relative;
  min-width: 0;
  min-height: 150px;
  overflow: hidden;
  padding: 16px;
  border: 1px solid rgba(var(--stat-accent-rgb), 0.18);
  border-radius: 18px;
  background:
    linear-gradient(145deg, rgba(var(--stat-accent-rgb), 0.095), rgba(255, 255, 255, 0.98) 58%),
    #ffffff;
  box-shadow: 0 9px 22px rgba(15, 23, 42, 0.05);
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease,
    border-color 0.2s ease;
}

.user-reports-stat-card::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 5px;
  height: 100%;
  background: var(--stat-accent);
  opacity: 0.9;
}

.user-reports-stat-card:hover {
  transform: translateY(-3px);
  border-color: rgba(var(--stat-accent-rgb), 0.34);
  box-shadow: 0 15px 32px rgba(15, 23, 42, 0.085);
}

.user-reports-stat-card--total {
  --stat-accent: #6b5cff;
  --stat-accent-rgb: 107, 92, 255;
}

.user-reports-stat-card--warning {
  --stat-accent: #c5ad18;
  --stat-accent-rgb: 197, 173, 24;
}

.user-reports-stat-card--primary,
.user-reports-stat-card--info {
  --stat-accent: #4258d8;
  --stat-accent-rgb: 66, 88, 216;
}

.user-reports-stat-card--success {
  --stat-accent: #2cac61;
  --stat-accent-rgb: 44, 172, 97;
}

.user-reports-stat-card--secondary {
  --stat-accent: #64748b;
  --stat-accent-rgb: 100, 116, 139;
}

.user-reports-stat-card--danger {
  --stat-accent: #dc3545;
  --stat-accent-rgb: 220, 53, 69;
}

.user-reports-stat-card__summary {
  min-width: 0;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  gap: 13px;
}

.user-reports-stat-card__top {
  display: flex;
  align-items: flex-start;
  gap: 11px;
}

.user-reports-stat-card__icon {
  width: 42px;
  height: 42px;
  flex: 0 0 42px;
  border: 1px solid rgba(var(--stat-accent-rgb), 0.16);
  border-radius: 14px;
  background: rgba(var(--stat-accent-rgb), 0.13);
  color: var(--stat-accent);
  display: grid;
  place-items: center;
}

.user-reports-stat-card__icon svg {
  width: 20px;
  height: 20px;
}

.user-reports-stat-card__heading {
  min-width: 0;
}

.user-reports-stat-card__heading h3 {
  margin: 0;
  color: var(--color-text);
  font-size: 0.98rem;
  font-weight: 950;
  line-height: 1.4;
}

.user-reports-stat-card__heading p {
  margin: 4px 0 0;
  color: var(--color-subtitle);
  font-size: 0.74rem;
  font-weight: 750;
  line-height: 1.55;
}

.user-reports-stat-card__value-row {
  margin-top: auto;
  display: flex;
  align-items: flex-end;
  gap: 7px;
}

.user-reports-stat-card__value-row strong {
  min-width: 28px;
  color: var(--stat-accent);
  font-size: clamp(1.65rem, 2.1vw, 2.15rem);
  font-weight: 950;
  line-height: 0.95;
}

.user-reports-stat-card__value-row > span {
  padding-bottom: 2px;
  color: var(--color-subtitle);
  font-size: 0.75rem;
  font-weight: 850;
}

.user-reports-stat-card__loading {
  width: 40px;
  height: 24px;
  border-radius: 8px;
  background: linear-gradient(
    90deg,
    rgba(var(--stat-accent-rgb), 0.12),
    rgba(var(--stat-accent-rgb), 0.28),
    rgba(var(--stat-accent-rgb), 0.12)
  );
  background-size: 220% 100%;
  display: inline-block;
  animation: user-reports-stat-loading 1.2s linear infinite;
}

@keyframes user-reports-stat-loading {
  from {
    background-position: 100% 0;
  }

  to {
    background-position: -120% 0;
  }
}

.user-reports-stat-card--with-stages {
  min-height: 0;
  margin-top: 14px;
  padding: 18px 20px;
  display: grid;
  grid-template-columns: minmax(230px, 0.8fr) minmax(0, 2.2fr);
  align-items: center;
  gap: 22px;
}

.user-reports-stat-card--with-stages .user-reports-stat-card__summary {
  min-height: 116px;
}

.user-reports-stat-card__stages {
  min-width: 0;
  padding-inline-start: 22px;
  border-inline-start: 1px dashed rgba(var(--stat-accent-rgb), 0.3);
  display: grid;
  gap: 10px;
}

.user-reports-stat-card__stages-title {
  color: var(--color-text);
  font-size: 0.78rem;
  font-weight: 900;
}

.user-reports-stat-card__stage-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.user-reports-stat-card__stage-list span {
  padding: 7px 10px;
  border: 1px solid rgba(var(--stat-accent-rgb), 0.17);
  border-radius: 999px;
  background: rgba(var(--stat-accent-rgb), 0.09);
  color: #3346b5;
  font-size: 0.72rem;
  font-weight: 900;
  line-height: 1.25;
}

/* =========================================================
   Five grouped map statuses
   ========================================================= */

.user-reports-map-legend {
  width: min(720px, 100%);
  display: grid;
  gap: 10px;
}

.user-reports-map-legend__items {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 8px 14px;
}

.user-reports-map-legend__item {
  --legend-color: #4258d8;

  min-width: max-content;
  color: var(--color-text);
  font-size: 0.78rem;
  font-weight: 900;
  display: inline-flex;
  align-items: center;
  gap: 7px;
}

.user-reports-map-legend__item i {
  width: 11px;
  height: 11px;
  flex: 0 0 11px;
  border: 2px solid rgba(255, 255, 255, 0.95);
  border-radius: 999px;
  background: var(--legend-color);
  box-shadow: 0 0 0 1px var(--legend-color);
}

.user-reports-map-legend__item--warning {
  --legend-color: #c5ad18;
}

.user-reports-map-legend__item--info {
  --legend-color: #4258d8;
}

.user-reports-map-legend__item--success {
  --legend-color: #2cac61;
}

.user-reports-map-legend__item--secondary {
  --legend-color: #64748b;
}

.user-reports-map-legend__item--danger {
  --legend-color: #dc3545;
}

.user-reports-map-legend__note {
  padding: 10px 12px;
  border: 1px solid rgba(66, 88, 216, 0.16);
  border-radius: 13px;
  background: rgba(66, 88, 216, 0.07);
  color: #3346b5;
  display: flex;
  align-items: flex-start;
  gap: 9px;
}

.user-reports-map-legend__note svg {
  width: 17px;
  height: 17px;
  flex: 0 0 17px;
  margin-top: 2px;
}

.user-reports-map-legend__note p {
  margin: 0;
  color: inherit;
  font-size: 0.73rem;
  font-weight: 750;
  line-height: 1.7;
}

.user-reports-map-legend__note strong {
  font-weight: 950;
}

.user-dashboard-map-card__actions {
  width: min(760px, 100%);
  max-width: 760px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
}

/* =========================================================
