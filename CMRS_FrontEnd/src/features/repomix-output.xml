import { FiBellOff } from 'react-icons/fi';
import NotificationItem from './NotificationItem';

function NotificationsList({
  notifications = [],
  onMarkAsRead,
  onDelete,
  onViewReport,
  emptyTitle = 'لا توجد إشعارات',
  emptyMessage = 'عند حدوث أي تحديث على بلاغاتك سيظهر هنا مباشرة.',
}) {
