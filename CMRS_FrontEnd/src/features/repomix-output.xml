  FiMapPin,
  FiPhone,
  FiUser,
} from 'react-icons/fi';

function ProfileInfoCard({
  values,
  isEditing = false,
  onChange,
  errors = {},
}) {
  function handleChange(event) {
    const { name, value } = event.target;

    onChange?.({
      ...values,
      [name]: value,
    });
