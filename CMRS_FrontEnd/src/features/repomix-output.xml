];

const PROGRESS_PROOF_STORAGE_KEY = 'cmrs:company-report-progress-proofs:v1';

const COMPANY_REPORT_PRIORITY_OPTIONS_FALLBACK = [
  { value: 'all', label: 'كل الأولويات' },
  { value: 'عالية', label: 'عالية' },
  { value: 'متوسطة', label: 'متوسطة' },
