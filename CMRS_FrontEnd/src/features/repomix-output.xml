  background: transparent;
  border: 0;
}

.reports-map__marker {
  position: relative;
  display: block;
  width: 26px;
  height: 26px;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);
  transition:
    transform 0.25s ease,
    box-shadow 0.25s ease,
    filter 0.25s ease;
}

.reports-map__marker-core {
  position: absolute;
  inset: 6px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
}

.reports-map__marker--success {
  background: #34a853;
}

.reports-map__marker--info {
  background: #4352db;
}

.reports-map__marker--warning {
  background: #d6c84f;
}

.reports-map__marker.is-active {
  transform: rotate(-45deg) scale(1.18);
  box-shadow: 0 12px 22px rgba(0, 0, 0, 0.25);
  filter: saturate(1.08);
}

.reports-map__marker.is-active::after {
  content: '';
  position: absolute;
  inset: -7px;
  border-radius: 50% 50% 50% 0;
  border: 2px solid rgba(2, 95, 72, 0.25);
  animation: reports-map-marker-pulse 1.4s ease-out infinite;
}

.reports-map__user-marker {
  position: relative;
  display: block;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #2f80ed;
  border: 4px solid #ffffff;
  box-shadow: 0 8px 18px rgba(47, 128, 237, 0.28);
