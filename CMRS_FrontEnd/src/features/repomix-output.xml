  }

  .company-dashboard-selected-report-card__actions {
    grid-template-columns: 1fr;
  }

  .company-report-modal-backdrop {
    padding: 18px 12px;
    align-items: start;
  }

  .company-report-modal {
    max-height: calc(100dvh - 36px);
    border-radius: 22px;
  }

  .company-report-modal__header {
    padding: 24px 18px 18px;
  }

  .company-report-modal__actions {
    width: 100%;
    justify-content: center;
  }

  .company-report-modal__open-btn {
    flex: 1;
    min-width: 0;
    white-space: normal;
    text-align: center;
  }

  .company-report-modal__close {
    width: 44px;
    height: 44px;
  }

  .company-report-modal__body {
    grid-template-columns: 1fr;
    padding: 18px;
  }

  .company-report-modal__images {
    grid-template-columns: 1fr;
  }

  .company-report-modal__images img {
    height: 150px;
  }

  .company-dashboard-filter-select__menu {
    max-height: 240px;
  }
}
