      report.AdminDecisionType,
  );

  const publicMessage = cleanPublicText(
    source.userMessage ||
      source.UserMessage ||
      source.publicMessage ||
      source.PublicMessage ||
      source.messageToUser ||
      source.MessageToUser ||
      report.userMessage ||
      report.UserMessage ||
      report.publicMessage ||
