  font-size: 0.82rem;
  font-weight: 700;
  line-height: 1.7;
  overflow-wrap: anywhere;
}

.add-report-location-picker__fixed-pin-marker {
  position: relative;
  display: block;
  width: 42px;
  height: 42px;
  border-radius: 50% 50% 50% 0;
