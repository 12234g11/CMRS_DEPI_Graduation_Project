  gap: 7px;
  font-size: 0.8rem;
  font-weight: 800;
  max-width: 100%;
  overflow-wrap: anywhere;
}

.user-profile-header__meta svg {
  width: 15px;
  height: 15px;
  color: var(--color-primary);
  flex-shrink: 0;
}

/* ===== Buttons ===== */

.user-profile-btn {
  min-height: 48px;
  padding: 11px 16px;
  border-radius: 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  font-family: inherit;
  font-size: 0.92rem;
  font-weight: 900;
  transition:
    transform var(--transition-base),
    opacity var(--transition-base),
    background var(--transition-base),
    border-color var(--transition-base);
}

.user-profile-btn:hover {
  transform: translateY(-1px);
}

.user-profile-btn:disabled {
  opacity: 0.58;
  cursor: not-allowed;
  transform: none;
}

.user-profile-btn svg {
  width: 17px;
  height: 17px;
}

.user-profile-btn--primary {
  background: var(--color-primary);
  color: #ffffff;
  box-shadow: 0 16px 28px rgba(2, 95, 72, 0.16);
}

.user-profile-btn--ghost {
  border: 1.5px solid rgba(2, 95, 72, 0.28);
  background: #ffffff;
  color: var(--color-primary);
}

/* ===== Layout ===== */

.user-profile-grid {
  display: grid;
  grid-template-columns: minmax(300px, 0.85fr) minmax(0, 1.3fr);
  gap: 20px;
  align-items: start;
  min-width: 0;
}

.user-profile-card {
  padding: 20px;
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: 26px;
  background: var(--color-surface);
  box-shadow: 0 18px 40px rgba(2, 95, 72, 0.05);
  display: grid;
  gap: 18px;
  min-width: 0;
}

.user-profile-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  text-align: right;
}

.user-profile-card__header h2 {
  margin: 0;
  color: var(--color-text);
  font-size: 1.18rem;
  font-weight: 950;
}

.user-profile-card__header p {
  margin: 5px 0 0;
  color: var(--color-subtitle);
  font-size: 0.84rem;
  font-weight: 700;
  line-height: 1.7;
}

.user-profile-card__icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.user-profile-card__icon svg {
  width: 21px;
  height: 21px;
}

/* ===== Info ===== */

.user-profile-info-list {
  display: grid;
  gap: 12px;
}

.user-profile-info-list article {
  padding: 14px;
  border: 1px solid rgba(2, 95, 72, 0.08);
  border-radius: 18px;
  background: rgba(248, 252, 249, 0.84);
  display: flex;
  align-items: flex-start;
  gap: 12px;
  min-width: 0;
}

.user-profile-info-list article > svg {
  width: 19px;
  height: 19px;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-top: 3px;
}

.user-profile-info-list span {
  display: block;
  color: var(--color-subtitle);
  font-size: 0.78rem;
  font-weight: 800;
}

.user-profile-info-list strong {
  display: block;
  margin-top: 4px;
  color: var(--color-text);
  font-size: 0.96rem;
  font-weight: 900;
  line-height: 1.6;
