  assigned: 'Assigned',
  inProgress: 'InProgress',
  pendingAdminApproval: 'PendingAdminApproval',
  needsCompletion: 'NeedsCompletion',
  unableToExecute: 'UnableToExecute',
  resolved: 'Resolved',
