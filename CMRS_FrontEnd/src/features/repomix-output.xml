@import 'leaflet/dist/leaflet.css';

.map-legend {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px 16px;
}

.map-legend__item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--color-text);
  font-size: 0.9rem;
  font-weight: 700;
}

.map-legend__dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
}

.map-legend__dot--success {
  background: #34a853;
}

.map-legend__dot--info {
  background: #4352db;
}

.map-legend__dot--warning {
  background: #d6c84f;
}

.map-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.map-filters__chip {
  min-height: 42px;
  padding: 10px 16px;
  border: 1.5px solid rgba(2, 95, 72, 0.16);
  border-radius: 999px;
  background: var(--color-surface);
  color: var(--color-primary);
  font-size: 0.92rem;
  font-weight: 800;
  transition:
    border-color var(--transition-base),
    background var(--transition-base),
    color var(--transition-base),
    transform var(--transition-base);
}

.map-filters__chip:hover {
  transform: translateY(-1px);
}

.map-filters__chip.is-active {
  background: var(--color-primary);
  color: var(--color-white);
  border-color: var(--color-primary);
}

.reports-map {
  position: relative;
  overflow: hidden;
  isolation: isolate;
  z-index: 0;
  border-radius: 24px;
}

.reports-map__canvas {
  width: 100%;
  border-radius: 24px;
  position: relative;
  z-index: 1;
  display: block;
}

.reports-map .leaflet-container {
  position: relative;
  z-index: 1;
  border-radius: inherit;
}

.reports-map .leaflet-pane,
.reports-map .leaflet-top,
.reports-map .leaflet-bottom,
.reports-map .leaflet-control-container {
  z-index: 2;
}

.reports-map__surface-glow {
  position: absolute;
  inset: 0;
