  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.company-report-table-summary__type {
  padding: 3px 8px;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.07);
