              >
                <FiSave />
                {isSaving ? 'جارٍ الحفظ...' : 'حفظ التعديل'}
              </button>
            </>
          ) : (
            <button
              type="button"
              className="user-profile-btn user-profile-btn--primary"
              onClick={onEdit}
