<file path="user/reports/notifications/user-notifications.css">
/* User notifications styles live here. */
.user-notifications-page {
  overflow: visible;
  gap: 20px;
  min-width: 0;
}

.user-notifications-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
  gap: 18px;
  align-items: stretch;
  padding: 22px;
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: 26px;
  background:
    radial-gradient(circle at top right, rgba(2, 95, 72, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(247, 255, 250, 1), rgba(255, 255, 255, 0.98));
  box-shadow: 0 18px 40px rgba(2, 95, 72, 0.06);
  min-width: 0;
}

.user-notifications-hero__content {
  display: grid;
  align-content: center;
  justify-items: end;
  gap: 10px;
  text-align: right;
  min-width: 0;
}

.user-notifications-hero__badge {
  min-height: 38px;
  padding: 8px 14px;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.86rem;
  font-weight: 900;
}

.user-notifications-hero__badge svg {
  width: 17px;
  height: 17px;
}

.user-notifications-hero__content h2 {
  margin: 0;
  color: var(--color-primary);
  font-size: clamp(1.45rem, 2.2vw, 2.2rem);
  font-weight: 900;
  line-height: 1.25;
  overflow-wrap: anywhere;
}

.user-notifications-hero__content p {
  margin: 0;
  max-width: 620px;
  color: var(--color-subtitle);
  font-size: 0.96rem;
  font-weight: 700;
  line-height: 1.8;
