.add-report-category-card {
  min-height: 136px;
  padding: 22px 18px;
  border: 1.5px solid var(--category-border, rgba(2, 95, 72, 0.1));
  border-radius: 18px;
  background:
    linear-gradient(
      135deg,
      var(--category-bg-start, #ffffff),
      var(--category-bg-end, #ffffff)
    );
  text-align: center;
  direction: rtl;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 14px;
  cursor: pointer;
  box-shadow: 0 10px 26px var(--category-shadow, rgba(2, 95, 72, 0.05));
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease,
    border-color 0.2s ease,
    background 0.2s ease;
}

