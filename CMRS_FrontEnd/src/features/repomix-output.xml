  inset: 0;
  border: 0;
  background: transparent;
  cursor: pointer;
}

.notification-report-modal {
  position: relative;
  z-index: 2;
  width: min(980px, 100%);
  max-height: calc(100dvh - 48px);
  border-radius: 28px;
  background: #ffffff;
  box-shadow: 0 28px 80px rgba(15, 23, 42, 0.28);
