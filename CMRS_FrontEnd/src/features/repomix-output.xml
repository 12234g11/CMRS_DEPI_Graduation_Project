export const REPORT_STATUS_LABELS = {
  [REPORT_STATUS_API_VALUES.underReview]: 'قيد المراجعة',
  [REPORT_STATUS_API_VALUES.accepted]: 'مقبول',
  [REPORT_STATUS_API_VALUES.rejected]: 'مرفوض',
