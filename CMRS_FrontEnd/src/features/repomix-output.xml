}

.company-submit-cannot-fix-btn {
  width: 100%;
  min-height: 45px;
  margin-top: 12px;
  border-radius: 12px;
  background: #b43f3f;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font: inherit;
  font-weight: 950;
  cursor: pointer;
}

.company-submit-cannot-fix-btn:disabled {
