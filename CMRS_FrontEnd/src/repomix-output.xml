/* Admin reports styles */

/* =========================
   Shared page spacing
========================= */

.admin-manage-reports-page,
.admin-report-details-page {
  gap: 22px;
}

/* =========================
   Manage reports toolbar
========================= */

.admin-manage-reports-card .dashboard-section-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
}

.admin-manage-reports-card .dashboard-section-card__header > div:first-child {
  flex-shrink: 0;
}

.admin-manage-reports-card .dashboard-section-card__action {
  flex: 1;
  min-width: 0;
}

.admin-manage-reports-card .dashboard-section-card__body {
  padding-top: 18px;
}

.admin-manage-reports-toolbar {
  width: 100%;
  display: grid;
  grid-template-columns: minmax(280px, 420px) minmax(145px, 165px) minmax(145px, 170px) 46px;
  align-items: center;
  justify-content: end;
  gap: 10px;
  direction: rtl;
}

.admin-manage-reports-search {
  width: 100%;
  min-width: 0;
  min-height: 44px;
  padding: 0 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.22);
  border-radius: 14px;
  background: var(--color-surface);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  gap: 10px;
  transition:
    border-color var(--transition-base),
    box-shadow var(--transition-base),
    background var(--transition-base);
}

.admin-manage-reports-search:focus-within {
  border-color: rgba(2, 95, 72, 0.5);
  box-shadow: 0 8px 22px rgba(2, 95, 72, 0.08);
