<file path="features/landing/landing.css">
section[id] {
  scroll-margin-top: 96px;
}

/* Navbar */
.landing-navbar {
  position: sticky;
  top: 0;
  z-index: 30;
  background: #ffffff;
  border-bottom: 1px solid rgba(2, 95, 72, 0.08);
  animation: navbar-slide-down 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  animation-fill-mode: both;
  will-change: transform, opacity;
}

@keyframes navbar-slide-down {
  from {
    opacity: 0;
    transform: translate3d(0, -24px, 0);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

.landing-navbar__inner {
  min-height: 76px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22px;
}

.landing-navbar__brand {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-shrink: 0;
}

.landing-navbar__brand-text {
  display: none;
}

.landing-navbar__brand strong,
.landing-navbar__brand span,
.landing-navbar__logo-mark {
  display: none;
}

.landing-navbar__logo-wrap {
  position: relative;
  width: 88px;
  height: 56px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.landing-navbar__logo-image {
    position: absolute;
    top: 68%;
    left: 50%;
    width: 230px;
    height: auto;
    max-width: none;
    display: block;
    object-fit: cover;
    transform: translate(-50%, -50%);
    transform-origin: center;
}


.landing-navbar__nav {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 22px;
  flex: 1;
}

.landing-navbar__nav-link {
  min-width: 58px;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  color: #333333;
  transform: translateY(0);
  transition:
    transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
    color 0.2s ease;
  will-change: transform;
}

.landing-navbar__nav-icon {
  width: 21px;
  height: 21px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: currentColor;
}

.landing-navbar__nav-label {
  font-size: 12px;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.landing-navbar__actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.landing-navbar__toggle {
  display: none;
  width: 46px;
  height: 46px;
  padding: 0;
  border: 1px solid rgba(2, 95, 72, 0.16);
  border-radius: 12px;
  background: #ffffff;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 5px;
  flex-shrink: 0;
}

.landing-navbar__toggle span {
  width: 20px;
  height: 2px;
  border-radius: 999px;
  background: var(--color-primary);
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.landing-navbar__toggle.is-active span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}

.landing-navbar__toggle.is-active span:nth-child(2) {
  opacity: 0;
}

.landing-navbar__toggle.is-active span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

.landing-navbar__mobile-menu {
  display: none;
}

/* Buttons */
.landing-btn {
  min-width: 132px;
  min-height: 48px;
  padding: 12px 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  font-weight: 700;
  transform: translateY(0);
  transition:
    transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
    background var(--transition-base),
    color var(--transition-base),
    border-color var(--transition-base),
    box-shadow 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform;
}

.landing-btn--primary {
  background: var(--color-primary);
  color: var(--color-white);
}

.landing-btn--primary:hover {
  background: var(--color-primary-dark);
}

.landing-btn--ghost {
  background: var(--color-white);
  border: 1px solid rgba(2, 95, 72, 0.22);
  color: var(--color-primary);
}

@media (hover: hover) and (pointer: fine) {
  .landing-btn:hover {
    transform: translateY(-2px);
  }

  .landing-navbar__nav-link:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  .landing-navbar__mobile-link:hover {
    transform: translateY(-2px);
    background: rgba(2, 95, 72, 0.08);
  }

  .landing-footer__socials a:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.18);
  }
}

/* Hero */
.hero-section {
  position: relative;
  min-height: calc(100vh - 76px);
  display: flex;
  align-items: center;
  background-color: #12342d;
  background:
    linear-gradient(90deg, rgba(3, 20, 16, 0.45), rgba(3, 20, 16, 0.2)),
    url('./images/hero-city.webp') center/cover no-repeat;
}

.hero-section__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.12);
}

.hero-section__content {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: flex-start;
  direction: rtl;
}

.hero-section__copy {
  width: 760px;
  max-width: 760px;
  padding-right: 72px;
  text-align: right;
  color: #f1f1f1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-section__title {
  margin: 0;
  font-family: var(--font-family-display, 'Cairo', sans-serif);
  font-weight: 800;
  font-size: 62px;
  line-height: 1.08;
  color: #f1f1f1;
  white-space: nowrap;
}

.hero-section__title span {
  color: #025f48;
  text-shadow: 0 0 3px rgba(0, 0, 0, 0.65), 0 0 6px rgba(0, 0, 0, 0.22);
}

.hero-section__subtitle {
  margin-top: 16px;
  margin-bottom: 0;
  width: 100%;
  max-width: 760px;
  font-family: var(--font-family-display, 'Cairo', sans-serif);
  font-weight: 700;
  font-size: 21px;
  line-height: 1.48;
  color: #f1f1f1;
}

.hero-section__subtitle-line {
  display: block;
}

.hero-section__subtitle-line--first {
  white-space: nowrap;
}

.hero-section__subtitle-line--second {
  margin-top: 2px;
}

.hero-section__actions {
  width: 100%;
  display: flex;
  justify-content: flex-start;
