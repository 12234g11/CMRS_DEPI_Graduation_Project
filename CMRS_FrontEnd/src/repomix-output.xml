  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.company-reports-inbox-summary h2 {
  margin: 0;
  color: var(--color-primary);
  font-size: 1.05rem;
  font-weight: 950;
}

.company-reports-inbox-summary p {
  margin: 6px 0 0;
  color: var(--color-subtitle);
  font-size: 0.86rem;
  font-weight: 850;
}

.company-reports-inbox-summary button {
  min-height: 42px;
  padding: 8px 16px;
