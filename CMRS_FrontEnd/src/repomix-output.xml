<file path="features/user/add-report/add-report.css">
.add-report-page {
  gap: 20px;
  min-width: 0;
}

.add-report-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28px;
  padding: 18px 28px;
  border: 1.5px solid rgba(2, 95, 72, 0.1);
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, rgba(232, 255, 232, 0.94), rgba(255, 255, 255, 0.98));
  box-shadow: var(--shadow-sm);
  min-width: 0;
}

.add-report-hero__intro {
  flex: 0 0 340px;
  max-width: 340px;
  text-align: right;
  order: 1;
  margin-inline-start: 0;
  margin-inline-end: auto;
  min-width: 0;
}

.add-report-hero__intro h1 {
  color: var(--color-primary);
  font-size: clamp(1.6rem, 1.9vw, 2.05rem);
  font-weight: 900;
  line-height: 1.08;
  margin: 0;
  overflow-wrap: anywhere;
}

.add-report-hero__intro p {
  margin-top: 6px;
  color: var(--color-subtitle);
  font-size: 0.96rem;
  font-weight: 700;
  line-height: 1.5;
  overflow-wrap: anywhere;
}

.add-report-hero__steps {
  order: 2;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 14px;
  direction: rtl;
}

.add-report-hero__step {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  flex: 0 0 auto;
  min-width: auto;
}

.add-report-hero__step::before {
  display: none;
}

.add-report-hero__step-badge {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: rgba(203, 213, 225, 0.72);
  color: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.86rem;
  font-weight: 900;
  flex-shrink: 0;
}

.add-report-hero__step.is-active .add-report-hero__step-badge,
.add-report-hero__step.is-complete .add-report-hero__step-badge {
  background: var(--color-primary);
}

.add-report-hero__step-label {
  color: #94a3b8;
  font-size: 0.92rem;
  font-weight: 800;
  white-space: nowrap;
  line-height: 1;
}

.add-report-hero__step.is-active .add-report-hero__step-label,
.add-report-hero__step.is-complete .add-report-hero__step-label {
  color: var(--color-primary);
}

.add-report-hero__step-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: rgba(148, 163, 184, 0.9);
  font-size: 1.15rem;
  line-height: 1;
  flex-shrink: 0;
  margin-inline: 2px 4px;
}

.add-report-hero__step.is-complete+.add-report-hero__step-arrow,
.add-report-hero__step.is-active+.add-report-hero__step-arrow {
  color: rgba(2, 95, 72, 0.68);
}

.add-report-shell {
  padding: 22px 24px 26px;
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  box-shadow: var(--shadow-sm);
  min-width: 0;
}

.add-report-step {
  display: grid;
  gap: 24px;
  min-width: 0;
}

.add-report-step__header {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-direction: row;
  gap: 16px;
  padding-bottom: 18px;
  border-bottom: 1px solid rgba(2, 95, 72, 0.08);
  min-width: 0;
  direction: ltr;
}

.add-report-step__heading {
  text-align: right;
  margin-inline-start: 0;
  margin-inline-end: 0;
  min-width: 0;
  direction: rtl;
  order: 1;
}

.add-report-step__header-icon {
  order: 2;
  flex-shrink: 0;
}

.add-report-step__heading h2 {
  color: var(--color-text);
  font-size: clamp(1.35rem, 2vw, 1.9rem);
  font-weight: 900;
  line-height: 1.1;
  overflow-wrap: anywhere;
}

.add-report-step__heading p {
  margin-top: 6px;
  color: var(--color-subtitle);
  font-size: 0.9rem;
  font-weight: 700;
  line-height: 1.6;
  overflow-wrap: anywhere;
}

.add-report-step__header-icon,
.add-report-card__icon {
  width: 46px;
  height: 46px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.add-report-step__header-icon svg,
.add-report-card__icon svg {
  width: 20px;
  height: 20px;
}

.add-report-category-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}

.add-report-category-card {
  min-height: 136px;
  min-width: 0;
  padding: 20px 18px;
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: 20px;
  background: #ffffff;
  box-shadow: 0 12px 30px rgba(2, 95, 72, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  text-align: center;
  transition:
    transform var(--transition-base),
    border-color var(--transition-base),
    box-shadow var(--transition-base),
    background var(--transition-base);
}

.add-report-category-card:hover {
  transform: translateY(-2px);
  border-color: rgba(2, 95, 72, 0.2);
}

.add-report-category-card.is-active {
  border-color: rgba(2, 95, 72, 0.42);
  background: linear-gradient(180deg, rgba(248, 255, 251, 1), rgba(255, 255, 255, 0.98));
  box-shadow: 0 18px 36px rgba(2, 95, 72, 0.08);
}

.add-report-category-card__icon {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.add-report-category-card__icon svg {
  width: 18px;
  height: 18px;
}

.add-report-category-card__icon.is-mint {
  background: rgba(16, 185, 129, 0.14);
  color: #10b981;
}

.add-report-category-card__icon.is-sky {
  background: rgba(59, 130, 246, 0.14);
  color: #3b82f6;
}

.add-report-category-card__icon.is-amber {
  background: rgba(245, 158, 11, 0.14);
  color: #f59e0b;
}

.add-report-category-card__icon.is-rose {
  background: rgba(239, 68, 68, 0.14);
  color: #ef4444;
}

.add-report-category-card__icon.is-violet {
  background: rgba(168, 85, 247, 0.14);
  color: #a855f7;
}

.add-report-category-card__icon.is-orange {
  background: rgba(249, 115, 22, 0.14);
  color: #f97316;
}

.add-report-category-card__icon.is-emerald {
  background: rgba(34, 197, 94, 0.14);
  color: #22c55e;
}

.add-report-category-card__icon.is-slate {
  background: rgba(148, 163, 184, 0.16);
  color: #64748b;
}

.add-report-category-card__label {
  color: var(--color-text);
  font-size: 1.03rem;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.add-report-category-card__subtitle {
  color: var(--color-subtitle);
  font-size: 0.8rem;
  font-weight: 700;
  overflow-wrap: anywhere;
}

.add-report-step__grid {
  display: grid;
  gap: 20px;
  min-width: 0;
}

.add-report-step__grid--details {
  grid-template-columns: minmax(280px, 0.86fr) minmax(0, 1.3fr);
}

.add-report-step__grid--location {
  grid-template-columns: minmax(320px, 0.92fr) minmax(0, 1.28fr);
  align-items: start;
}

.add-report-card {
  padding: 20px;
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: 22px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(249, 253, 251, 1));
  box-shadow: 0 12px 24px rgba(2, 95, 72, 0.04);
  min-width: 0;
}

.add-report-card__header {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-direction: row;
  gap: 16px;
  text-align: right;
  direction: ltr;
}

.add-report-card__header > div {
  order: 1;
  text-align: right;
  direction: rtl;
  margin: 0;
}

.add-report-card__icon {
  order: 2;
  flex-shrink: 0;
}
.add-report-card__header h3 {
  color: var(--color-text);
  font-size: 1.08rem;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.add-report-card__header p {
  margin-top: 4px;
  color: var(--color-subtitle);
  font-size: 0.78rem;
  font-weight: 700;
  overflow-wrap: anywhere;
}

.add-report-upload-card {
  display: grid;
  align-content: start;
  gap: 18px;
}

.add-report-upload-card__dropzone {
  min-height: 236px;
  border: 1.5px dashed rgba(2, 95, 72, 0.18);
  border-radius: 18px;
  background: rgba(248, 252, 249, 0.96);
  display: grid;
  place-items: center;
  text-align: center;
  gap: 10px;
  padding: 24px 18px;
  cursor: pointer;
  transition:
    border-color var(--transition-base),
    background var(--transition-base),
    transform var(--transition-base);
}

.add-report-upload-card__dropzone:hover {
  border-color: rgba(2, 95, 72, 0.32);
  background: rgba(242, 251, 246, 1);
  transform: translateY(-1px);
}

.add-report-upload-card__dropzone-icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.add-report-upload-card__dropzone-icon svg {
  width: 22px;
  height: 22px;
}

.add-report-upload-card__dropzone strong {
  color: var(--color-text);
  font-size: 0.98rem;
  font-weight: 800;
  overflow-wrap: anywhere;
}

.add-report-upload-card__dropzone small {
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 700;
  overflow-wrap: anywhere;
}

.add-report-upload-card__preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.add-report-upload-card__preview {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 16px;
  overflow: hidden;
  background: rgba(2, 95, 72, 0.06);
}

.add-report-upload-card__preview img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.add-report-upload-card__remove {
  position: absolute;
  top: 10px;
  left: 10px;
  width: 34px;
  height: 34px;
  border-radius: 12px;
  background: rgba(15, 23, 42, 0.78);
  color: #ffffff;
  display: grid;
  place-items: center;
}

.add-report-upload-card__remove svg {
  width: 16px;
  height: 16px;
}

.add-report-fields-card {
  display: grid;
  gap: 18px;
}

.add-report-fields-card__section {
  display: grid;
  gap: 12px;
}

.add-report-fields-card__counter {
  color: #94a3b8;
  font-size: 0.86rem;
  font-weight: 800;
  text-align: right;
}

.add-report-fields-card textarea,
.add-report-fields-card input {
  min-height: 56px;
  padding: 14px 16px;
  font-size: 0.95rem;
  text-align: right;
}

.add-report-fields-card textarea::placeholder,
.add-report-fields-card input::placeholder {
  opacity: 1;
}

.add-report-fields-card textarea {
  resize: vertical;
  min-height: 168px;
}

.add-report-severity-selector {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.add-report-severity-chip {
  min-height: 48px;
  padding: 10px 14px;
  border: 1.5px solid rgba(2, 95, 72, 0.1);
  border-radius: 14px;
  background: rgba(248, 252, 249, 0.96);
  color: var(--color-subtitle);
  font-size: 0.92rem;
  font-weight: 800;
  transition:
    transform var(--transition-base),
    border-color var(--transition-base),
    background var(--transition-base),
    color var(--transition-base);
}

.add-report-severity-chip:hover {
  transform: translateY(-1px);
}

.add-report-severity-chip.is-active {
  background: #ffffff;
}

.add-report-severity-chip.is-warning {
  border-color: rgba(245, 158, 11, 0.52);
  color: #c77c00;
  box-shadow: 0 10px 24px rgba(245, 158, 11, 0.12);
}

.add-report-severity-chip.is-success {
  border-color: rgba(16, 185, 129, 0.42);
  color: #13895f;
  box-shadow: 0 10px 24px rgba(16, 185, 129, 0.12);
}

.add-report-severity-chip.is-danger {
