  height: 18px;
}

.add-report-location-picker__confirm-btn {
  position: absolute;
  right: 18px;
  top: 18px;
  min-height: 48px;
  padding: 12px 16px;
  border-radius: 999px;
  background: var(--color-primary);
  color: var(--color-white);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.14);
