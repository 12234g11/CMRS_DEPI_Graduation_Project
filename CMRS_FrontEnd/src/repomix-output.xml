              <FiInfo />
              عنوان المشكلة
            </span>
            <strong>{values.title || '—'}</strong>
          </div>

          <div className="add-report-review-card__field">
            <span className="add-report-review-card__label">
              <FiMessageSquare />
              وصف المشكلة
            </span>
            <p>{values.description || '—'}</p>
          </div>

          <div className="add-report-review-card__field">
            <span className="add-report-review-card__label">
              <FiMapPin />
              الموقع
            </span>
            <strong>{locationLabel || '—'}</strong>
