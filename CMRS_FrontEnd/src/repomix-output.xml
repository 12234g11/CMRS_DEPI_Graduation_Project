.form-field--governorate {
  position: relative;
}

.governorate-bs-dropdown {
  width: 100%;
  direction: rtl;
}

.governorate-bs-dropdown__toggle {
  width: 100%;
  min-height: 58px;
  padding: 0 18px;
  border: 1.5px solid rgba(2, 95, 72, 0.16);
  border-radius: 18px;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.98),
    rgba(245, 252, 248, 0.96)
  );
  color: var(--color-text);
  font-family: inherit;
  font-size: 1rem;
  font-weight: 800;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow:
    0 10px 24px rgba(2, 95, 72, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.95);
  transition:
    border-color var(--transition-base),
    box-shadow var(--transition-base),
    background var(--transition-base);
}

.governorate-bs-dropdown__toggle:hover,
.governorate-bs-dropdown__toggle:focus,
.governorate-bs-dropdown__toggle.show {
  border-color: var(--color-primary);
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 1),
    rgba(238, 252, 244, 0.98)
  );
  box-shadow:
    0 0 0 4px rgba(2, 95, 72, 0.1),
    0 14px 30px rgba(2, 95, 72, 0.08);
}

.governorate-bs-dropdown__toggle::after {
  margin-right: auto;
  margin-left: 0;
  color: var(--color-primary);
}

.governorate-bs-dropdown__toggle.is-selected {
  color: var(--color-primary);
}

.governorate-bs-dropdown__menu {
  width: 100%;
  margin-top: 10px;
  padding: 8px;
  border: 1.5px solid rgba(2, 95, 72, 0.14);
  border-radius: 18px;
  background: #ffffff;
  text-align: right;
  box-shadow:
    0 18px 40px rgba(2, 95, 72, 0.14),
    0 6px 14px rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.governorate-bs-dropdown__item {
  min-height: 46px;
  padding: 10px 14px;
  border-radius: 13px;
  color: var(--color-text);
  font-family: inherit;
  font-size: 0.96rem;
  font-weight: 800;
  text-align: right;
  direction: rtl;
  transition:
    background var(--transition-base),
    color var(--transition-base),
    transform var(--transition-base);
}

.governorate-bs-dropdown__item:hover,
.governorate-bs-dropdown__item:focus {
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  transform: translateX(-2px);
}

.governorate-bs-dropdown__item.active,
.governorate-bs-dropdown__item:active {
  background: var(--color-primary);
  color: var(--color-white);
}
