.admin-assign-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 18px rgba(2, 95, 72, 0.14);
}

.admin-view-btn:hover {
  background: var(--color-primary-dark);
}

.admin-assign-btn:hover {
  background: #e38c00;
}

.admin-view-btn svg,
.admin-assign-btn svg {
  width: 15px;
  height: 15px;
}

/* =========================
   Badges and pills
========================= */

.admin-report-rating {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.admin-report-rating svg {
  width: 17px;
  height: 17px;
  fill: #c6df00;
  color: #c6df00;
}

.admin-report-status,
.admin-report-priority,
.admin-report-company-pill,
.admin-report-type-pill {
  min-height: 30px;
  padding: 6px 11px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 0.78rem;
  font-weight: 900;
  white-space: nowrap;
}

.admin-report-status--success,
.admin-report-priority--success,
.admin-report-type-pill--success {
  background: rgba(52, 168, 83, 0.14);
  color: #218540;
}

.admin-report-status--warning,
.admin-report-priority--warning,
.admin-report-type-pill--warning {
  background: rgba(255, 193, 7, 0.18);
  color: #b17800;
}

.admin-report-status--info {
  background: rgba(90, 107, 255, 0.12);
  color: #4352db;
}

.admin-report-priority--danger,
.admin-report-type-pill--danger {
  background: rgba(239, 124, 124, 0.18);
  color: #c24a4a;
}

.admin-report-priority::before,
.admin-report-status::after {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: currentColor;
}

.admin-report-company-pill {
  background: rgba(2, 95, 72, 0.1);
  color: var(--color-primary);
}

.admin-report-muted {
  color: rgba(111, 111, 111, 0.55);
  font-weight: 900;
}

/* =========================
   Details page layout
========================= */

.admin-report-back-link {
  width: fit-content;
  min-height: 40px;
  padding: 8px 14px;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.88rem;
  font-weight: 900;
  transition:
    transform var(--transition-base),
    background var(--transition-base);
}

.admin-report-back-link:hover {
  transform: translateY(-1px);
  background: rgba(2, 95, 72, 0.13);
}

.admin-report-details-grid {
  display: grid;
  grid-template-columns: minmax(280px, 0.42fr) minmax(0, 1fr);
  gap: 18px;
  align-items: start;
}

.admin-report-details-left,
.admin-report-details-right {
  display: grid;
  gap: 18px;
}

.admin-report-details-card {
  background: var(--color-surface);
  border: 1.5px solid rgba(2, 95, 72, 0.08);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.admin-report-details-card.admin-report-action-card {
  overflow: visible;
}

.admin-report-card-header,
.admin-report-description-header {
  padding: 18px 20px 14px;
  border-bottom: 1px solid rgba(2, 95, 72, 0.07);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}

.admin-report-card-header h2,
.admin-report-description-header h2 {
  margin: 0;
  color: var(--color-text);
  font-size: 1.08rem;
  font-weight: 950;
  line-height: 1.4;
}

.admin-report-card-header p {
  margin-top: 3px;
  color: var(--color-subtitle);
  font-size: 0.78rem;
  font-weight: 800;
}

/* =========================
   Description card
========================= */

.admin-report-description-header {
  padding: 16px 20px;
}

.admin-report-description-content {
  padding: 18px 20px 22px;
}

.admin-report-description-content p {
  min-height: 0;
  padding: 0;
  margin: 0;
  color: var(--color-text);
  font-size: 1rem;
  font-weight: 850;
  line-height: 1.9;
  text-align: right;
  display: block;
}

.admin-report-description-card > p,
.admin-report-description-card header p {
  display: none;
}

/* =========================
   Summary card
========================= */

.admin-report-summary-card {
  padding: 8px 0;
}

.admin-report-summary-row {
  padding: 18px 22px;
  display: grid;
  grid-template-columns: 46px minmax(90px, 0.75fr) minmax(0, 1fr);
  align-items: center;
  gap: 14px;
  border-bottom: 1px solid rgba(2, 95, 72, 0.07);
}

.admin-report-summary-row:last-child {
  border-bottom: 0;
}

.admin-report-summary-row__icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: rgba(2, 95, 72, 0.1);
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.admin-report-summary-row__icon svg {
  width: 20px;
  height: 20px;
}

.admin-report-summary-row__label strong,
.admin-report-summary-row__label span {
  display: block;
}

.admin-report-summary-row__label strong {
  color: var(--color-subtitle);
  font-size: 0.84rem;
  font-weight: 900;
}

.admin-report-summary-row__label span {
  color: rgba(146, 146, 146, 0.85);
  font-size: 0.72rem;
  font-weight: 800;
}

.admin-report-summary-row__value {
  color: var(--color-text);
  font-size: 1rem;
  font-weight: 950;
}

/* =========================
   Images card
========================= */

.admin-report-images-card,
.admin-report-map-card,
.admin-reporter-card,
.admin-report-action-card {
  padding-bottom: 18px;
}

.admin-report-images-count {
  min-height: 36px;
  padding: 7px 12px;
  border-radius: 12px;
  background: rgba(2, 95, 72, 0.06);
  color: var(--color-text-soft);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.84rem;
  font-weight: 900;
}

.admin-report-images-count svg {
  width: 16px;
  height: 16px;
}

.admin-report-image-preview {
  height: 260px;
  margin: 18px 20px 14px;
  border-radius: 14px;
  overflow: hidden;
  background: #e8eeee;
}

.admin-report-image-preview img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.admin-report-images-footer {
  margin-inline: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}

.admin-report-community-rating {
  min-width: 220px;
  padding: 12px 16px;
  border: 1px solid rgba(2, 95, 72, 0.08);
  border-radius: 14px;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 7px;
  box-shadow: 0 6px 16px rgba(2, 95, 72, 0.05);
}

.admin-report-community-rating span {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: #ff9f0a;
  font-weight: 950;
}

.admin-report-community-rating svg {
  width: 16px;
  height: 16px;
  fill: currentColor;
}

.admin-report-community-rating small {
  color: var(--color-subtitle);
  font-weight: 800;
}

.admin-report-community-rating b {
  margin-inline-start: auto;
  color: var(--color-text);
  font-size: 0.78rem;
  font-weight: 900;
}

.admin-report-thumbnails {
  display: flex;
  align-items: center;
  gap: 8px;
}

.admin-report-thumbnails button {
  width: 50px;
  height: 42px;
  padding: 2px;
  border: 2px solid transparent;
  border-radius: 10px;
  overflow: hidden;
  background: #f0f0f0;
  transition:
    border-color var(--transition-base),
    transform var(--transition-base);
}

.admin-report-thumbnails button:hover,
.admin-report-thumbnails button.is-active {
  transform: translateY(-1px);
  border-color: var(--color-primary);
}

.admin-report-thumbnails img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 7px;
}

/* =========================
   Map card
========================= */

.admin-report-map-card .reports-map,
.admin-report-map-card .reports-map__canvas,
.admin-report-map-card .leaflet-container {
  border-radius: 16px;
}

.admin-report-map-card .reports-map {
  margin: 18px 20px 0;
}

/* =========================
   Reporter card
========================= */

.admin-reporter-card__avatar {
  width: 58px;
  height: 58px;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: grid;
  place-items: center;
}

.admin-reporter-card__avatar svg {
  width: 24px;
  height: 24px;
}

.admin-reporter-card__body {
  padding: 20px;
  display: grid;
  grid-template-columns: minmax(180px, 0.8fr) minmax(190px, 1fr) minmax(220px, 1.1fr);
  align-items: center;
  gap: 22px;
}

.admin-reporter-card__identity strong,
.admin-reporter-card__identity span {
  display: block;
}

.admin-reporter-card__identity strong {
  color: var(--color-text);
  font-size: 1rem;
  font-weight: 950;
}

.admin-reporter-card__identity span {
  color: var(--color-subtitle);
  font-weight: 800;
}

.admin-reporter-card__contacts {
  display: grid;
  gap: 8px;
}

.admin-reporter-card__contacts span {
  color: var(--color-text-soft);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.88rem;
  font-weight: 850;
}

.admin-reporter-card__contacts svg {
  width: 17px;
  height: 17px;
  color: var(--color-primary);
}

.admin-reporter-trust {
  min-height: 88px;
  padding: 14px;
  border-radius: 16px;
  background: rgba(232, 255, 232, 0.55);
  display: grid;
  grid-template-columns: 58px minmax(0, 1fr);
  align-items: center;
  gap: 14px;
}

.admin-reporter-trust__circle {
  width: 56px;
  height: 56px;
  border: 5px solid rgba(2, 95, 72, 0.18);
  border-radius: 50%;
  background: #fff;
  color: var(--color-primary);
  display: grid;
  place-items: center;
}

.admin-reporter-trust__circle strong {
  font-size: 1rem;
  font-weight: 950;
}

.admin-reporter-trust__content span,
.admin-reporter-trust__content b {
  display: block;
}

.admin-reporter-trust__content span {
  color: var(--color-subtitle);
  font-size: 0.78rem;
  font-weight: 800;
}

.admin-reporter-trust__content b {
  color: var(--color-primary);
  font-size: 0.9rem;
  font-weight: 950;
}

.admin-reporter-trust__bar {
  height: 7px;
  margin-top: 10px;
  border-radius: 999px;
  background: rgba(2, 95, 72, 0.12);
  overflow: hidden;
}

.admin-reporter-trust__bar span {
  height: 100%;
  border-radius: inherit;
  background: var(--color-primary);
}

/* =========================
   Status and company form
========================= */

.admin-report-details-form {
  display: grid;
  gap: 18px;
  overflow: visible;
}

.admin-report-action-card {
  padding-bottom: 20px;
  transition: min-height var(--transition-base);
}

.admin-report-form-group {
  padding: 18px 22px 0;
  display: grid;
  gap: 10px;
  overflow: visible;
}

.admin-report-form-group label {
  color: var(--color-subtitle);
  font-size: 0.98rem;
  font-weight: 900;
}

.admin-report-current-company {
  min-height: 46px;
  padding: 10px 14px;
  border: 1.5px dashed rgba(2, 95, 72, 0.16);
  border-radius: 14px;
  background: #fafafa;
  color: var(--color-subtitle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.admin-report-save-btn {
  width: min(680px, calc(100% - 40px));
  min-height: 58px;
  margin: 0 auto;
  border-radius: 16px;
  background: var(--color-primary);
  color: #fff;
  font-size: 1.1rem;
  font-weight: 950;
  box-shadow: 0 10px 20px rgba(2, 95, 72, 0.18);
  transition:
    transform var(--transition-base),
    background var(--transition-base),
    opacity var(--transition-base);
}

.admin-report-save-btn:hover {
  transform: translateY(-1px);
  background: var(--color-primary-dark);
}

.admin-report-save-btn:disabled {
  opacity: 0.75;
  cursor: wait;
}

/* =========================
   Not found
========================= */

.admin-report-not-found {
  padding: 32px;
  text-align: center;
}

.admin-report-not-found h2 {
  color: var(--color-text);
  font-weight: 950;
}

.admin-report-not-found p {
  margin: 8px 0 18px;
  color: var(--color-subtitle);
  font-weight: 800;
}

.admin-report-not-found button {
  min-height: 42px;
  padding: 8px 16px;
  border-radius: 999px;
  background: var(--color-primary);
  color: #fff;
  font-weight: 900;
}

/* =========================
   Responsive
========================= */

@media (max-width: 1250px) {
  .admin-manage-reports-card .dashboard-section-card__header {
    display: grid;
    grid-template-columns: 1fr;
  }

  .admin-manage-reports-card .dashboard-section-card__action {
    width: 100%;
  }

  .admin-manage-reports-toolbar {
    grid-template-columns: minmax(260px, 1fr) minmax(135px, 155px) minmax(135px, 160px) 46px;
    justify-content: stretch;
  }

  .admin-report-details-grid {
    grid-template-columns: 1fr;
  }

  .admin-reporter-card__body {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .admin-manage-reports-page,
  .admin-report-details-page {
    gap: 18px;
  }

  .admin-manage-reports-card .dashboard-section-card__header {
    gap: 12px;
  }

  .admin-manage-reports-toolbar {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 44px;
    gap: 8px;
  }

  .admin-manage-reports-search {
    grid-column: 1 / -1;
    min-height: 40px;
    padding-inline: 12px;
    border-radius: 13px;
  }

  .admin-manage-reports-search input {
    height: 38px;
    font-size: 0.86rem;
  }

  .admin-report-filter-select__button {
    min-height: 40px;
    padding-inline: 10px;
    border-radius: 13px;
    font-size: 0.8rem;
  }

  .admin-manage-reports-filter-btn {
    width: 44px;
    min-width: 44px;
    height: 40px;
    border-radius: 13px;
  }

  .admin-report-filter-select__menu {
    border-radius: 14px;
  }

  .admin-report-filter-select--overlay .admin-report-filter-select__menu {
    top: calc(100% + 6px);
  }

  .admin-report-filter-select__option {
    min-height: 36px;
    font-size: 0.8rem;
  }

  .admin-report-description-header {
    padding: 14px 16px;
  }

  .admin-report-description-content {
    padding: 16px;
  }

  .admin-report-description-content p {
    font-size: 0.96rem;
    line-height: 1.8;
  }

  .admin-report-type-pill {
    padding-inline: 10px;
    font-size: 0.76rem;
  }

  .admin-report-summary-row {
    grid-template-columns: 42px 1fr;
  }

  .admin-report-summary-row__value {
    grid-column: 1 / -1;
    padding-inline-start: 56px;
  }

  .admin-report-image-preview {
    height: 210px;
    margin-inline: 14px;
  }

  .admin-report-images-footer {
    margin-inline: 14px;
    display: grid;
  }

  .admin-report-community-rating {
    width: 100%;
    min-width: 0;
  }

  .admin-report-map-card .reports-map {
    margin-inline: 14px;
  }

  .admin-reporter-card__body {
    padding: 16px;
  }

  .admin-report-form-group {
    padding-inline: 16px;
  }

  .admin-report-save-btn {
    width: calc(100% - 28px);
  }
}

@media (max-width: 420px) {
  .admin-manage-reports-toolbar {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 42px;
    gap: 7px;
  }

  .admin-report-filter-select__button {
    padding-inline: 8px;
    font-size: 0.76rem;
  }

  .admin-manage-reports-filter-btn {
    width: 42px;
    min-width: 42px;
  }

  .admin-report-actions {
    gap: 6px;
  }

  .admin-view-btn,
  .admin-assign-btn {
    padding-inline: 10px;
  }
}
/* =========================
   Company assignment panel
========================= */

.admin-company-assignment-panel {
  padding-bottom: 20px;
  overflow: visible;
}

.admin-company-assignment-current {
  margin: 18px 22px 0;
  padding: 14px 16px;
  border: 1.5px dashed rgba(2, 95, 72, 0.16);
  border-radius: 14px;
  background: #fafafa;
  display: grid;
  gap: 4px;
}

.admin-company-assignment-current span {
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 850;
}

.admin-company-assignment-current strong {
  color: var(--color-text);
  font-size: 1rem;
  font-weight: 950;
}

.admin-company-assignment-toolbar {
  margin: 16px 22px 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(180px, 240px);
  gap: 10px;
  align-items: start;
}

.admin-company-assignment-search {
  min-height: 44px;
  padding: 0 13px;
  border: 1.5px solid rgba(2, 95, 72, 0.16);
  border-radius: 14px;
  background: var(--color-surface);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  gap: 10px;
}

.admin-company-assignment-search svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

.admin-company-assignment-search input {
  width: 100%;
  height: 42px;
  border: 0;
  outline: 0;
  background: transparent;
  color: var(--color-text);
  font-weight: 850;
}

.admin-company-assignment-hint {
  margin: 14px 22px 0;
  padding: 12px 14px;
  border-radius: 14px;
  background: rgba(2, 95, 72, 0.07);
  color: var(--color-text-soft);
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 0.84rem;
  font-weight: 850;
  line-height: 1.7;
}

.admin-company-assignment-hint svg {
  width: 18px;
  height: 18px;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-top: 3px;
}

.admin-company-recommendations {
  margin: 18px 22px 0;
}

.admin-company-recommendations__title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.admin-company-recommendations__title h3 {
  color: var(--color-text);
  font-size: 1rem;
  font-weight: 950;
}

.admin-company-recommendations__title span {
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 850;
}

.admin-company-recommendations__grid {
  margin-top: 12px;
  display: grid;
  gap: 12px;
}

.admin-company-empty-state {
  margin-top: 12px;
  padding: 20px;
  border-radius: 14px;
  background: #fafafa;
  color: var(--color-subtitle);
  font-weight: 900;
  text-align: center;
}

.admin-company-recommendation-card {
  padding: 15px;
  border: 1.5px solid rgba(2, 95, 72, 0.1);
  border-radius: 16px;
  background: #fff;
  box-shadow: 0 8px 22px rgba(2, 95, 72, 0.05);
  display: grid;
  gap: 12px;
  transition:
    transform var(--transition-base),
    border-color var(--transition-base),
    box-shadow var(--transition-base);
}

.admin-company-recommendation-card:hover,
.admin-company-recommendation-card.is-selected {
  transform: translateY(-1px);
  border-color: rgba(2, 95, 72, 0.38);
  box-shadow: 0 14px 28px rgba(2, 95, 72, 0.1);
}

.admin-company-recommendation-card.is-selected {
  background: rgba(232, 255, 232, 0.35);
}

.admin-company-recommendation-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.admin-company-recommendation-card__title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}

.admin-company-recommendation-card h3 {
  color: var(--color-text);
  font-size: 1rem;
  font-weight: 950;
}

.admin-company-recommendation-card p {
  margin-top: 4px;
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 850;
}

.admin-company-recommended-badge {
  min-height: 26px;
  padding: 5px 9px;
  border-radius: 999px;
  background: rgba(255, 159, 10, 0.16);
  color: #c77b00;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.72rem;
  font-weight: 950;
}

.admin-company-match-score {
  width: 62px;
  min-width: 62px;
  height: 62px;
  border-radius: 18px;
  background: rgba(2, 95, 72, 0.08);
  color: var(--color-primary);
  display: grid;
  place-items: center;
  text-align: center;
}

.admin-company-match-score strong,
.admin-company-match-score span {
  display: block;
}

.admin-company-match-score strong {
  font-size: 1.05rem;
  font-weight: 950;
}

.admin-company-match-score span {
  font-size: 0.68rem;
  font-weight: 850;
}

.admin-company-description {
  color: var(--color-text-soft) !important;
  line-height: 1.8;
}

.admin-company-metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8px;
}

.admin-company-metrics span {
  min-height: 34px;
  padding: 7px 9px;
