}

.user-profile-avatar {
  width: 82px;
  height: 82px;
  border-radius: 26px;
  background:
    linear-gradient(135deg, rgba(2, 95, 72, 0.12), rgba(2, 95, 72, 0.04)),
    #ffffff;
  color: var(--color-primary);
