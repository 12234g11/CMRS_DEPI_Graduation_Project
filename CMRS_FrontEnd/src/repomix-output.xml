.reports-map__marker--warning {
  background: #d6c84f;
}

.reports-map__marker.is-active {
  transform: rotate(-45deg) scale(1.18);
  box-shadow: 0 12px 22px rgba(0, 0, 0, 0.25);
  filter: saturate(1.08);
}

.reports-map__marker.is-active::after {
  content: '';
  position: absolute;
  inset: -7px;
  border-radius: 50% 50% 50% 0;
  border: 2px solid rgba(2, 95, 72, 0.25);
  animation: reports-map-marker-pulse 1.4s ease-out infinite;
}

.reports-map__user-marker {
  position: relative;
  display: block;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #2f80ed;
  border: 4px solid #ffffff;
  box-shadow: 0 8px 18px rgba(47, 128, 237, 0.28);
}

.reports-map__user-marker-core {
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
}

.reports-map__user-marker::after {
  content: '';
  position: absolute;
  inset: -10px;
  border-radius: 50%;
  border: 2px solid rgba(47, 128, 237, 0.25);
  animation: reports-map-user-marker-pulse 1.6s ease-out infinite;
}

@keyframes reports-map-marker-pulse {
  0% {
    opacity: 0.9;
    transform: scale(0.95);
  }

  100% {
    opacity: 0;
    transform: scale(1.35);
  }
}

@keyframes reports-map-user-marker-pulse {
  0% {
    opacity: 0.95;
    transform: scale(0.9);
  }

  100% {
    opacity: 0;
    transform: scale(1.4);
  }
}

.reports-map__popup {
  min-width: 170px;
  display: grid;
  gap: 4px;
  direction: rtl;
  text-align: right;
}

.reports-map__popup strong {
  color: var(--color-primary);
  font-weight: 800;
}

.reports-map__popup span,
.reports-map__popup small {
  color: var(--color-text-soft);
  font-weight: 700;
}

@media (max-width: 768px) {
  .map-legend {
    gap: 8px 12px;
  }

  .map-legend__item {
    font-size: 0.84rem;
  }

  .reports-map__controls {
    top: 10px;
    right: 10px;
    left: 10px;
    align-items: stretch;
  }

  .reports-map__control-btn--locate {
    width: 46px;
    height: 46px;
    min-width: 46px;
    min-height: 46px;
    border-radius: 14px;
  }

  .reports-map__control-btn-icon {
    width: 22px;
    height: 22px;
  }

  .reports-map__control-btn-icon svg {
    width: 14px;
    height: 14px;
  }

  .reports-map__route-summary {
    left: 10px;
    right: 10px;
    bottom: 10px;
    max-width: none;
  }
}
</file>

