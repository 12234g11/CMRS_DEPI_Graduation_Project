.add-report-location-picker__fixed-pin-card-content strong {
  color: var(--color-text);
  font-size: 0.96rem;
  font-weight: 900;
  line-height: 1.75;
  overflow-wrap: anywhere;
}

.add-report-location-picker__fixed-pin-card-content small {
  color: var(--color-subtitle);
  font-size: 0.82rem;
  font-weight: 700;
  line-height: 1.7;
  overflow-wrap: anywhere;
}

.add-report-location-picker__fixed-pin-marker {
  position: relative;
  display: block;
  width: 42px;
  height: 42px;
  border-radius: 50% 50% 50% 0;
