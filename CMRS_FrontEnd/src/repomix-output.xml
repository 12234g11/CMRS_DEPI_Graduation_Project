import { getDefaultRouteByRole } from '../../shared/navigation';
import { useAuth } from '../../features/auth/hooks/useAuth';

function GuestRoute() {
  const { isAuthenticated, user } = useAuth();

  if (isAuthenticated && user?.role) {
