          <img src={previewImage} alt={values.title || 'معاينة البلاغ'} />

          {values.imagePreviews.length > 1 ? (
            <span className="add-report-review-image-card__count">
              +{values.imagePreviews.length - 1} صور إضافية
            </span>
          ) : null}
